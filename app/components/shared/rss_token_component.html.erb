<div class="mb-10">
  <div class="flex items-center justify-between mb-4">
    <h2 class="m-0 text-xl font-semibold">RSS Feed Token</h2>
  </div>
  <div class="bg-white border border-slate-200 rounded-lg p-5">
    <p class="text-sm text-slate-600 mb-4">
      Use a personal RSS token to subscribe to campaign log feeds for your games.
      The token grants read-only access; anyone with this token can read your feeds.
    </p>
    <% if token_present? %>
      <div class="mb-4">
        <div class="text-xs text-slate-400 uppercase tracking-wide mb-1">Your Token</div>
        <code class="text-sm bg-slate-100 px-2 py-1 rounded break-all"><%= token_value %></code>
      </div>
      <div class="flex gap-2">
        <%= button_to "Rotate Token", generate_path, method: :post,
              class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block",
              data: { confirm: "Rotating your token will invalidate all existing feed URLs. Continue?" } %>
        <%= button_to "Revoke Token", revoke_path, method: :delete,
              class: "px-5 py-2 border border-slate-300 text-slate-700 rounded text-base cursor-pointer hover:bg-slate-50 inline-block",
              data: { confirm: "Revoking your token will stop all feed subscriptions. Continue?" } %>
      </div>
    <% else %>
      <%= button_to "Generate RSS Token", generate_path, method: :post,
            class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block" %>
    <% end %>
  </div>
</div>
