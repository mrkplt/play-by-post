<div data-controller="lightbox" data-action="keydown@document->lightbox#closeOnEscape">
  <div class="grid grid-cols-[repeat(auto-fill,minmax(100px,120px))] gap-2" data-testid="gallery-grid">
    <% @game_files.each do |gf| %>
      <div class="bg-white border border-slate-200 rounded-lg overflow-hidden cursor-pointer relative hover:shadow-md transition-shadow"
           data-testid="gallery-card"
           data-action="click->lightbox#open"
           data-lightbox-html="<%= escape_once(lightbox_html_for(gf).to_s) %>"
           data-lightbox-filename="<%= gf.filename %>"
           data-lightbox-download="<%= download_url_for(gf) %>"
           <% if (du = delete_url_for(gf)) %>data-lightbox-delete="<%= du %>"<% end %>>
        <div class="w-full aspect-square flex items-center justify-center bg-slate-50 overflow-hidden">
          <% if (th = thumb_html_for(gf)) %>
            <%= th %>
          <% else %>
            <div class="text-2xl font-bold text-slate-500 uppercase tracking-wide bg-slate-100 w-full h-full flex items-center justify-center" data-testid="gallery-card-placeholder"><%= gf.file_extension %></div>
          <% end %>
        </div>
        <div class="p-2 flex items-center gap-1">
          <span class="flex-1 min-w-0 text-xs text-ink whitespace-nowrap overflow-hidden text-ellipsis" title="<%= gf.filename %>" data-testid="gallery-card-filename"><%= gf.filename %></span>
        </div>
      </div>
    <% end %>
  </div>

  <div data-lightbox-target="modal" class="fixed inset-0 z-[1000] flex items-center justify-center p-4" hidden data-testid="lightbox" data-action="click->lightbox#closeOnBackdrop">
    <div class="absolute inset-0 bg-black/60" data-lightbox-backdrop></div>
    <div class="relative bg-white rounded-lg max-w-[90vw] max-h-[90vh] flex flex-col overflow-hidden">
      <div class="flex items-center justify-between px-4 py-3 border-b border-slate-200 gap-4">
        <span class="font-semibold text-sm min-w-0 whitespace-nowrap overflow-hidden text-ellipsis" data-lightbox-title></span>
        <div class="flex items-center gap-2 shrink-0">
          <a href="#" data-lightbox-download class="text-[0.8rem] py-[0.3rem] px-3 bg-slate-500 text-white rounded cursor-pointer hover:bg-slate-600 inline-block no-underline" data-turbo="false">Download</a>
          <% if @is_gm %>
            <button data-lightbox-delete-btn class="text-[0.8rem] py-[0.3rem] px-3 bg-white text-red-600 border border-red-200 rounded cursor-pointer hover:bg-red-50" data-action="click->lightbox#confirmDelete" hidden>Delete</button>
          <% end %>
          <button class="bg-transparent border-none text-xl cursor-pointer text-slate-500 p-1 leading-none hover:text-ink" data-action="click->lightbox#close" aria-label="Close">&times;</button>
        </div>
      </div>
      <div class="flex items-center justify-center p-4 overflow-auto flex-1" data-lightbox-image></div>
    </div>
  </div>
</div>
