<div class="flex items-center justify-between mb-6">
  <h1 class="m-0 text-2xl font-bold">Campaign Log</h1>
  <div class="flex gap-2">
    <% if is_gm? %>
      <%= link_to "Edit Game", edit_game_path(@game),
          class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block no-underline" %>
    <% end %>
    <%= link_to "RSS Feed", game_scene_summaries_path(@game, format: :rss),
        class: "px-5 py-2 border border-slate-300 text-slate-700 rounded text-base cursor-pointer hover:bg-slate-50 inline-block no-underline" %>
  </div>
</div>

<% if summaries_empty? %>
  <p class="text-slate-400">No summaries yet. Summaries appear here once scenes are resolved.</p>
<% else %>
  <% @summaries.each do |summary| %>
    <%= render Shared::SceneSummaryEntryComponent.new(
          summary: SceneSummaryPresenter.new(summary),
          game: @game
        ) %>
  <% end %>
  <%== @pagy.series_nav %>
<% end %>
