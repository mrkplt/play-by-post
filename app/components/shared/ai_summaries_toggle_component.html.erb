<div class="bg-white border border-slate-200 rounded-lg p-5 mb-6">
  <h2 class="text-lg font-semibold mb-4">AI Scene Summaries</h2>
  <p class="text-sm text-slate-600 mb-4">
    AI summaries are currently <strong><%= status_text %></strong>.
    When enabled, a summary is automatically generated each time a scene is resolved.
  </p>
  <%= button_to toggle_label, toggle_path, method: :patch,
      class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block no-underline" %>
</div>
