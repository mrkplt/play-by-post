<div class="sidebar-brand flex items-center justify-between">
  <%= link_to "Play by Post", root_path %>
  <button data-action="click->sidebar#close" class="md:hidden text-sidebar-text hover:opacity-75 cursor-pointer" aria-label="Close navigation">
    <%= helpers.icon "cancel-01", class: "w-5 h-5" %>
  </button>
</div>

<nav class="flex-1">
  <%= link_to "My Games", root_path, class: "sidebar-section-label" %>

  <% if signed_in? && @user.games.any? %>
    <% @user.games_by_recent_activity(limit: 8).each do |game| %>
      <% is_gm = game_master_in?(game) %>
      <%= link_to game_path(game), class: "sidebar-link flex items-center justify-between" do %>
        <span><%= game.name %></span>
        <% if is_gm %>
          <%= helpers.icon "crown-03", class: "w-4 h-4 text-accent" %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
</nav>

<% if signed_in? %>
  <div class="sidebar-user">
    <div class="mb-2 flex items-center justify-between">
      <%= link_to profile_path, class: "flex items-center gap-2 text-sm hover:opacity-75" do %>
        <span><%= @current_user.display_name_or_email %></span>
        <%= helpers.icon "settings-01", class: "w-4 h-4" %>
      <% end %>
    </div>
    <%= link_to "Sign out", destroy_user_session_path, class: "sidebar-link py-1 m-0" %>
  </div>
<% end %>
