<button data-action="click->sidebar#open"
        data-sidebar-target="toggle"
        class="md:hidden fixed top-4 left-4 z-50 bg-[#2b2d31] text-[#cdd1d9] border border-[#3d3f45] rounded px-3 py-2 text-lg cursor-pointer"
        aria-label="Open navigation">
  &#9776;
</button>

<div class="sidebar-backdrop md:hidden"
     hidden
     data-sidebar-target="backdrop"
     data-action="click->sidebar#close"></div>

<aside class="sidebar" data-sidebar-target="sidebar">
  <%= render Shared::SidebarComponent.new(current_user: @current_user) %>
</aside>
