<div class="max-w-sm mx-auto mt-16 p-8 bg-white border border-slate-200 rounded-lg">
  <% if @email_sent %>
    <h1>Check your email</h1>
    <p>We sent a sign-in link to your inbox. Click it to continue — no password needed.</p>
    <p class="text-xs text-slate-500 mt-4">Didn't get it? Check your spam folder, or <%= link_to "try again", new_user_session_path %>.</p>
    <% if Rails.env.development? %>
      <p class="text-xs mt-2"><%= link_to "Open Letter Opener", "/letter_opener" %></p>
    <% end %>
  <% else %>
    <h1>Sign in</h1>
    <p class="text-slate-500 mb-6">Enter your email and we'll send you a link to sign in. No password required.</p>
    <%= form_with url: user_session_path, method: :post do |f| %>
      <div class="mb-4">
        <%= f.label :email, "Email address", class: "block font-medium mb-1 text-sm" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "you@example.com", name: "user[email]", class: "w-full px-3 py-2 border border-slate-300 rounded text-base" %>
      </div>
      <%= f.submit "Send sign-in link", class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block no-underline" %>
    <% end %>
  <% end %>
</div>
