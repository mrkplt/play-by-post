<div class="auth-card">
  <% if @email_sent %>
    <h1>Check your email</h1>
    <p>We sent a sign-in link to your inbox. Click it to continue — no password needed.</p>
    <p style="font-size:0.85rem; color:#64748b; margin-top:1rem;">Didn't get it? Check your spam folder, or <%= link_to "try again", new_user_session_path %>.</p>
  <% else %>
    <h1>Sign in</h1>
    <p style="color:#64748b; margin-bottom:1.5rem;">Enter your email and we'll send you a link to sign in. No password required.</p>
    <%= form_with url: user_session_path, method: :post do |f| %>
      <div class="field">
        <%= f.label :email, "Email address" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "you@example.com", name: "user[email]" %>
      </div>
      <%= f.submit "Send sign-in link" %>
    <% end %>
  <% end %>
</div>
