<nav class="text-sm mb-4 text-slate-500">
  <%= link_to "Games", root_path %> &rsaquo;
  <%= link_to @game.name, game_path(@game) %> &rsaquo;
  Game Files
</nav>

<div class="flex items-center justify-between mb-4">
  <h1 class="m-0 text-xl font-semibold">Game Files</h1>
</div>

<% if @is_gm %>
  <div class="bg-white border border-slate-200 rounded-lg p-5 mb-4">
    <h3 class="mt-0">Upload File</h3>
    <%= form_with url: game_game_files_path(@game), multipart: true do |f| %>
      <div class="mb-4">
        <label class="block mb-1 text-sm font-medium text-slate-700">File</label>
        <input type="file" name="game_file[file]" accept=".pdf,.doc,.docx,.txt,.md,.jpg,.jpeg,.png,.gif,.webp"
               class="block max-w-md text-sm text-slate-700 border border-slate-300 rounded px-3 py-2 cursor-pointer bg-white file:mr-3 file:py-1 file:px-3 file:rounded file:border-0 file:text-sm file:font-medium file:bg-slate-100 file:text-slate-700 hover:file:bg-slate-200">
        <p class="text-xs text-slate-400 mt-1 mb-0">PDF, Word, text, markdown, or image. Max 25MB.</p>
      </div>
      <%= f.submit "Upload", class: "px-5 py-2 bg-blue-600 text-white rounded text-base cursor-pointer hover:bg-blue-700 inline-block no-underline" %>
    <% end %>
  </div>
<% end %>

<% if @game_files.empty? %>
  <p class="text-slate-400">No files uploaded yet.</p>
<% else %>
  <%= render "game_files/gallery", game_files: @game_files, game: @game, is_gm: @is_gm %>
<% end %>
