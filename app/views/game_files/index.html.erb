<nav style="font-size:0.85rem; margin-bottom:1rem; color:#64748b;">
  <%= link_to "Games", root_path %> &rsaquo;
  <%= link_to @game.name, game_path(@game) %> &rsaquo;
  Game Files
</nav>

<div class="section__header">
  <h1>Game Files</h1>
</div>

<% if @is_gm %>
  <div class="card">
    <h3 style="margin-top:0;">Upload File</h3>
    <%= form_with url: game_game_files_path(@game), multipart: true do |f| %>
      <div class="field">
        <input type="file" name="game_file[file]" accept=".pdf,.doc,.docx,.txt,.md,.jpg,.jpeg,.png,.gif,.webp">
        <p style="font-size:0.8rem; color:#94a3b8; margin:0.25rem 0 0;">PDF, Word, text, markdown, or image. Max 25MB.</p>
      </div>
      <%= f.submit "Upload", class: "btn" %>
    <% end %>
  </div>
<% end %>

<% if @game_files.empty? %>
  <p style="color:#94a3b8;">No files uploaded yet.</p>
<% else %>
  <div data-controller="lightbox" data-action="keydown@document->lightbox#closeOnEscape">
    <div class="gallery-grid">
      <% @game_files.each do |gf| %>
        <%
          thumb = gf.thumbnail
          thumb_html = thumb ? image_tag(url_for(thumb), alt: gf.filename, loading: "lazy") : nil

          lightbox_html = if gf.image? && gf.display_image
            tag.img(src: url_for(gf.display_image), alt: gf.filename)
          elsif thumb
            tag.img(src: url_for(thumb), alt: gf.filename, style: "max-width:100%;")
          else
            tag.div(class: "lightbox__placeholder") do
              tag.div(gf.file_extension, class: "lightbox__placeholder-ext") +
              tag.div(number_to_human_size(gf.file.byte_size), class: "lightbox__placeholder-size")
            end
          end

          download_url = gf.file.attached? ? rails_blob_path(gf.file, disposition: "attachment") : "#"
        %>
        <div class="gallery-card"
             data-action="click->lightbox#open"
             data-lightbox-html="<%= escape_once(lightbox_html.to_s) %>"
             data-lightbox-filename="<%= gf.filename %>"
             data-lightbox-download="<%= download_url %>">
          <div class="gallery-card__thumb">
            <% if thumb_html %>
              <%= thumb_html %>
            <% else %>
              <div class="gallery-card__placeholder"><%= gf.file_extension %></div>
            <% end %>
          </div>
          <div class="gallery-card__info">
            <span class="gallery-card__filename" title="<%= gf.filename %>"><%= gf.filename %></span>
            <div class="gallery-card__actions" data-lightbox-stop>
              <%= link_to "\u2B73", download_url, class: "gallery-card__action", title: "Download", data: { turbo: false } %>
              <% if @is_gm %>
                <%= button_to "\u2715", game_game_file_path(@game, gf), method: :delete,
                    class: "gallery-card__action gallery-card__action--delete",
                    title: "Delete",
                    form: { data: { turbo_confirm: "Delete this file?" }, style: "display:inline;" } %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <div data-lightbox-target="modal" class="lightbox" hidden data-action="click->lightbox#closeOnBackdrop">
      <div class="lightbox__backdrop" data-lightbox-backdrop></div>
      <div class="lightbox__content">
        <div class="lightbox__header">
          <span class="lightbox__title" data-lightbox-title></span>
          <div class="lightbox__header-actions">
            <a href="#" data-lightbox-download class="btn btn--secondary" style="font-size:0.8rem; padding:0.3rem 0.75rem;" data-turbo="false">Download</a>
            <button class="lightbox__close" data-action="click->lightbox#close" aria-label="Close">&times;</button>
          </div>
        </div>
        <div class="lightbox__body" data-lightbox-image></div>
      </div>
    </div>
  </div>
<% end %>
