<div id="<%= dom_id(post) %>" class="post <%= post.is_ooc? ? 'post--ooc' : '' %>" data-ooc="<%= post.is_ooc? %>">
  <div class="post__meta">
    <% participant = scene.scene_participants.find { |sp| sp.user_id == post.user_id } %>
    <strong><%= participant&.display_name || post.user.display_name || post.user.email %></strong>
    &middot;
    <time data-local-time="<%= post.created_at.iso8601 %>"><%= post.created_at.strftime("%b %-d, %Y %-I:%M %p") %></time>
    <% if post.is_ooc? %>
      <span class="badge badge--gray">OOC</span>
    <% end %>
    <% if post.last_edited_at.present? %>
      <span style="font-style:italic;">(edited)</span>
    <% end %>
    <% if post.editable_by?(current_user) %>
      &middot; <%= link_to "Edit", edit_game_scene_post_path(game, scene, post), style: "font-size:0.8rem;" %>
    <% end %>
  </div>
  <div class="post__content"><%= render_markdown(post.content) %></div>
  <% if post.image.attached? %>
    <div style="margin-top:0.5rem;">
      <%= image_tag post.display_image, style: "max-width:100%; border-radius:4px;" %>
    </div>
  <% end %>
</div>
