<%= form_with model: [game, scene, post], multipart: true, data: { controller: "markdown-preview" } do |f| %>
  <% if post.errors.any? %>
    <div class="bg-red-50 border border-red-300 rounded-lg px-3 py-2 mb-3 text-sm text-red-600">
      <% post.errors.full_messages.each do |msg| %>
        <div><%= msg %></div>
      <% end %>
    </div>
  <% end %>

  <div class="mb-4">
    <%= f.text_area :content, rows: 5, placeholder: "Write your post...", class: "w-full px-3 py-2 border border-slate-300 rounded text-base",
        data: { markdown_preview_target: "input", action: "input->markdown-preview#update" } %>
  </div>

  <div data-markdown-preview-target="preview" class="hidden border border-slate-200 rounded-lg px-3 py-3 mb-3 min-h-12 bg-slate-50"></div>

  <div class="mb-2">
    <%= f.label :image, "Image (optional)", class: "block font-medium mb-1 text-sm text-slate-600" %>
    <%= f.file_field :image, accept: "image/jpeg,image/png,image/gif,image/webp", class: "text-sm" %>
    <p class="text-xs text-slate-400 mt-0.5">JPEG, PNG, GIF, or WebP. Max 10MB.</p>
  </div>

  <div class="flex flex-col gap-2" data-testid="composer-actions">
    <label class="text-sm cursor-pointer">
      <%= f.check_box :is_ooc %> Out of character
    </label>
    <button type="button" class="px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block no-underline text-sm" data-action="click->markdown-preview#togglePreview">
      Preview
    </button>
    <%= f.submit "Post", class: "px-5 py-2 bg-blue-600 text-white rounded text-base cursor-pointer hover:bg-blue-700 inline-block no-underline", style: "min-height: 44px;" %>
  </div>
<% end %>
