<%= turbo_stream.remove "no_posts_message" %>
<%= turbo_stream.append "posts" do %>
  <%= render Shared::PostItemComponent.new(
        post: PostPresenter.new(@post, scene_participants: @scene.scene_participants.to_a),
        game: @game,
        current_user: current_user,
        scene: @scene
      ) %>
<% end %>
<%= turbo_stream.replace "post_composer" do %>
  <%= render Shared::PostComposerComponent.new(post: Post.new, game: @game, scene: @scene) %>
<% end %>
