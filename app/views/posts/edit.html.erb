<h2>Edit Post</h2>

<%= form_with model: [@game, @scene, @post] do |f| %>
  <div class="mb-4">
    <%= f.text_area :content, rows: 6, class: "w-full px-3 py-2 border border-slate-300 rounded text-base" %>
  </div>
  <%= f.submit "Save", class: "px-5 py-2 bg-blue-600 text-white rounded text-base cursor-pointer hover:bg-blue-700 inline-block no-underline" %>
  <%= link_to "Cancel", game_scene_path(@game, @scene), class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block no-underline" %>
<% end %>
