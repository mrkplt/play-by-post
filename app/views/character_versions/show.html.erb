<%= render(Ui::BreadcrumbComponent.new) do %>
  <%= link_to "Games", root_path %> &rsaquo;
  <%= link_to @game.name, game_path(@game) %> &rsaquo;
  <%= link_to @character.name, game_character_path(@game, @character) %> &rsaquo;
  Version <time data-local-time="<%= @version.created_at.iso8601 %>"><%= @version.created_at.strftime("%b %-d, %Y %-I:%M %p") %></time>
<% end %>

<div class="flex items-center justify-between mb-4">
  <h1 class="m-0 text-xl font-semibold"><%= @character.name %> <span style="font-weight:normal; color:#64748b;">— <time data-local-time="<%= @version.created_at.iso8601 %>"><%= @version.created_at.strftime("%b %-d, %Y %-I:%M %p") %></time></span></h1>
  <%= link_to "Back to character", game_character_path(@game, @character), class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block no-underline" %>
</div>

<p style="font-size:0.85rem; color:#64748b;">
  Edited by: <%= UserPresenter.new(@version.edited_by).display_name_or_email %>
</p>

<div class="bg-white border border-slate-200 rounded-lg p-5 mb-4">
  <% if @version.content.present? %>
    <div class="markdown-base character-sheet-content"><%= render_markdown(@version.content) %></div>
  <% else %>
    <p style="color:#94a3b8;">No content in this version.</p>
  <% end %>
</div>
