<h2>Edit Participants — <%= @scene.title %></h2>

<%= form_with url: game_scene_participants_path(@game, @scene), method: :patch do |f| %>
  <div class="mb-4">
    <p class="text-sm text-slate-500 mb-3">The GM is always included automatically.</p>
    <% @players_with_characters.each do |user, characters| %>
      <div class="mb-3">
        <div class="text-sm font-semibold text-slate-700 mb-1">
          <%= user.display_name || user.email %>
        </div>
        <% if characters.empty? %>
          <div class="text-sm text-slate-400 pl-4">No active characters</div>
        <% else %>
          <% characters.each do |character| %>
            <label class="block font-normal mb-0.5 pl-4">
              <input type="checkbox" name="character_ids[]" value="<%= character.id %>"
                <%= "checked" if @current_character_ids.include?(character.id) %>>
              <%= character.name %>
            </label>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>

  <%= f.submit "Update Participants", class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block no-underline" %>
  <%= link_to "Cancel", game_scene_path(@game, @scene), class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block no-underline" %>
<% end %>
