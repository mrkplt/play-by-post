<h1>New Game</h1>

<%= form_with model: @game do |f| %>
  <div class="mb-4">
    <%= f.label :name, class: "block font-medium mb-1 text-sm" %>
    <%= f.text_field :name, maxlength: 200, autofocus: true, class: "w-full px-3 py-2 border border-slate-300 rounded text-base" %>
    <% if @game.errors[:name].any? %>
      <span class="text-red-600 text-sm"><%= @game.errors[:name].first %></span>
    <% end %>
  </div>

  <div class="mb-4">
    <%= f.label :description, "Description (optional)", class: "block font-medium mb-1 text-sm" %>
    <%= f.text_area :description, rows: 4, class: "w-full px-3 py-2 border border-slate-300 rounded text-base" %>
  </div>

  <p class="text-sm text-slate-500">You will become the Game Master of this game.</p>

  <%= f.submit "Create game", data: { confirm: "Create this game? You will be the GM." } %>
<% end %>
