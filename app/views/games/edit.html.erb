<%= render(Ui::BreadcrumbComponent.new) do %>
  <%= link_to "Games", root_path %> &rsaquo;
  <%= link_to @game.name, game_path(@game) %> &rsaquo;
  Edit
<% end %>

<div class="max-w-2xl">
  <h1 class="mb-6">Game Settings</h1>

  <!-- Game Details -->
  <div class="bg-white border border-slate-200 rounded-lg p-5 mb-6">
    <h2 class="text-lg font-semibold mb-4">Game Details</h2>

    <%= form_with model: @game, local: true do |f| %>
      <% if @game.errors.any? %>
        <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded text-red-800 text-sm">
          <strong><%= pluralize(@game.errors.count, "error") %> prohibited this game from being saved:</strong>
          <ul class="mt-2 list-disc list-inside">
            <% @game.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-4">
        <%= f.label :name, class: "block font-medium mb-1 text-sm" %>
        <%= f.text_field :name, maxlength: 200, class: "w-full px-3 py-2 border border-slate-300 rounded text-base" %>
      </div>

      <div class="mb-4">
        <%= f.label :description, "Description (optional)", class: "block font-medium mb-1 text-sm" %>
        <%= f.text_area :description, rows: 4, class: "w-full px-3 py-2 border border-slate-300 rounded text-base" %>
      </div>

      <div class="flex gap-2">
        <%= f.submit "Save Changes", class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block no-underline" %>
        <%= link_to "Cancel", game_path(@game), class: "px-5 py-2 border border-slate-300 text-slate-700 rounded text-base cursor-pointer hover:bg-slate-50 inline-block no-underline" %>
      </div>
    <% end %>
  </div>

  <!-- Post Image Attachments -->
  <div class="bg-white border border-slate-200 rounded-lg p-5 mb-6">
    <h2 class="text-lg font-semibold mb-4">Post Images</h2>
    <p class="text-sm text-slate-600 mb-4">
      Image attachments on posts are currently <strong><%= @game.images_disabled? ? "disabled" : "enabled" %></strong>.
    </p>
    <%= button_to @game.images_disabled? ? "Enable Image Attachments" : "Disable Image Attachments",
        toggle_images_disabled_game_path(@game), method: :patch, class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block no-underline" %>
  </div>

  <!-- Character Sheets Visibility -->
  <div class="bg-white border border-slate-200 rounded-lg p-5 mb-6">
    <h2 class="text-lg font-semibold mb-4">Character Sheets</h2>
    <p class="text-sm text-slate-600 mb-4">
      Character sheets are currently <strong><%= @game.sheets_hidden? ? "hidden" : "visible" %></strong> to players.
    </p>
    <%= button_to @game.sheets_hidden? ? "Show Character Sheets" : "Hide Character Sheets",
        toggle_sheets_hidden_game_path(@game), method: :patch, class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block no-underline" %>
  </div>

  <!-- Player Management -->
  <div class="bg-white border border-slate-200 rounded-lg p-5">
    <h2 class="text-lg font-semibold mb-4">Players & Invitations</h2>
    <p class="text-sm text-slate-600 mb-4">
      Manage who can play in this game and send invitations.
    </p>
    <%= link_to "Manage Players", game_player_management_path(@game), class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block no-underline" %>
  </div>
</div>
