<div class="flex items-center justify-between mb-4">
  <h1>My Games</h1>
  <%= link_to "New Game", new_game_path, class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block no-underline" %>
</div>

<% if @dashboard_items.empty? %>
  <div class="bg-white border border-slate-200 rounded-lg p-5 mb-4 text-center text-slate-500">
    <p class="text-base mb-2">You're not in any games yet.</p>
    <p class="mb-6">Create a new game to get started, or ask a Game Master to invite you.</p>
    <%= link_to "Create a game", new_game_path, class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block no-underline" %>
  </div>
<% else %>
  <% @dashboard_items.each do |item| %>
    <% game = item[:game] %>
    <% membership = item[:membership] %>
    <div class="bg-white border border-slate-200 rounded-lg p-5 mb-4">
      <div class="flex justify-between items-start">
        <div>
          <%= link_to game.name, game_path(game), class: "text-base font-bold no-underline" %>
          <% if item[:new_activity] %>
            <%= render(Ui::BadgeComponent.new(variant: :yellow)) { "New" } %>
          <% end %>
          <% if membership.removed? %>
            <%= render(Ui::BadgeComponent.new(variant: :gray)) { "Former" } %>
          <% end %>
        </div>
        <%= render(Ui::BadgeComponent.new(variant: membership.game_master? ? :blue : :green)) { membership.game_master? ? "GM" : "Player" } %>
      </div>
      <div class="text-xs text-slate-500 mt-2">
        <% if item[:primary_character] %>
          <%= link_to item[:primary_character].name, game_character_path(game, item[:primary_character]) %> &middot;
        <% end %>
        <%= item[:active_scene_count] %> active <%= "scene".pluralize(item[:active_scene_count]) %>
      </div>
    </div>
  <% end %>
<% end %>
