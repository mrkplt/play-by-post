<nav style="font-size:0.85rem; margin-bottom:1rem; color:#64748b;">
  <%= link_to "Games", root_path %> &rsaquo;
  <%= @game.name %>
</nav>

<div class="section__header">
  <h1><%= @game.name %></h1>
  <% if @is_gm %>
    <%= link_to "Manage Players", game_player_management_path(@game), class: "btn btn--secondary" %>
    <%= button_to @game.sheets_hidden? ? "Show Character Sheets" : "Hide Character Sheets",
        toggle_sheets_hidden_game_path(@game), method: :patch, class: "btn btn--secondary" %>
  <% end %>
</div>
<% if @game.description.present? %>
  <p><%= @game.description %></p>
<% end %>

<!-- Character Roster -->
<div class="section">
  <div class="section__header">
    <h2>Characters</h2>
    <%= link_to "New Character", new_game_character_path(@game), class: "btn btn--secondary" %>
  </div>
  <% if @characters.empty? %>
    <p style="color:#94a3b8;">No characters yet.</p>
  <% else %>
    <div style="display:flex; flex-wrap:wrap; gap:0.75rem;">
      <% @characters.each do |character| %>
        <div class="card" style="flex:1; min-width:160px; max-width:260px; padding:0.75rem;">
          <div style="font-weight:600;">
            <%= link_to character.name, game_character_path(@game, character) %>
          </div>
          <div style="font-size:0.8rem; color:#64748b; margin-top:0.2rem;">
            <%= character.user.display_name || character.user.email %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<!-- Active Scenes -->
<div class="section">
  <div class="section__header">
    <h2>Active Scenes</h2>
    <div style="display:flex; gap:0.5rem;">
      <%= link_to "All Scenes", game_scenes_path(@game), class: "btn btn--secondary" %>
      <% if @is_gm %>
        <%= link_to "New Scene", new_game_scene_path(@game), class: "btn" %>
      <% end %>
    </div>
  </div>
  <% if @active_scenes.empty? %>
    <p style="color:#94a3b8;">No active scenes.</p>
  <% else %>
    <% @active_scenes.each do |scene| %>
      <%= render "scenes/scene_card", scene: scene, game: @game %>
    <% end %>
  <% end %>
</div>

<!-- Game Files -->
<div class="section">
  <div class="section__header">
    <h2>Game Files</h2>
    <% if @is_gm %>
      <%= link_to "Manage Files", game_game_files_path(@game), class: "btn btn--secondary" %>
    <% else %>
      <%= link_to "View Files", game_game_files_path(@game), class: "btn btn--secondary" %>
    <% end %>
  </div>
  <% if @game_files.empty? %>
    <p style="color:#94a3b8; font-size:0.9rem;">No files uploaded yet.</p>
  <% else %>
    <div style="font-size:0.9rem;">
      <% @game_files.each do |gf| %>
        <div style="padding:0.4rem 0; border-bottom:1px solid #f1f5f9;">
          <% if gf.file.attached? %>
            <%= link_to gf.filename, rails_blob_path(gf.file, disposition: "attachment") %>
          <% else %>
            <%= gf.filename %>
          <% end %>
          <span style="color:#94a3b8; margin-left:0.5rem;"><%= gf.created_at.strftime("%b %-d") %></span>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
