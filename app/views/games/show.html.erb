<%= render(Ui::BreadcrumbComponent.new) do %>
  <%= link_to "Games", root_path %> &rsaquo;
  <%= @game.name %>
  <% if @is_gm %>
    <%= link_to edit_game_path(@game), class: "md:hidden hover:opacity-75 inline-flex align-middle ml-1" do %>
      <%= icon "settings-01", class: "w-3.5 h-3.5 text-ink" %>
    <% end %>
  <% end %>
<% end %>

<div class="hidden md:flex items-center gap-3 mb-6">
  <h1 class="text-3xl font-bold m-0 leading-none"><%= @game.name %></h1>
  <% if @is_gm %>
    <%= link_to edit_game_path(@game), class: "hover:opacity-75" do %>
      <%= icon "settings-01", class: "w-4 h-4 text-ink" %>
    <% end %>
  <% end %>
</div>
<% if @game.description.present? %>
  <p><%= @game.description %></p>
<% end %>

<!-- Character Roster -->
<div class="mb-10">
  <div class="flex items-center justify-between mb-4">
    <h2 class="m-0 text-xl font-semibold">Characters</h2>
    <%= link_to "New Character", new_game_character_path(@game), class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block no-underline" %>
  </div>
  <% if @characters.empty? %>
    <p class="text-slate-400">No characters yet.</p>
  <% else %>
    <div class="flex flex-wrap gap-3">
      <% @characters.each do |character| %>
        <div class="bg-white border border-slate-200 rounded-lg flex-1 min-w-40 max-w-64 p-3">
          <div class="font-semibold">
            <%= link_to character.name, game_character_path(@game, character) %>
          </div>
          <div class="text-xs text-slate-500 mt-0.5">
            <%= character.user.display_name || character.user.email %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<!-- Active Scenes -->
<div class="mb-10">
  <div class="flex items-center justify-between mb-4">
    <h2 class="m-0 text-xl font-semibold">Active Scenes</h2>
    <div class="flex gap-2">
      <%= link_to "All Scenes", game_scenes_path(@game), class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block no-underline" %>
      <% if @is_gm %>
        <%= link_to "New Scene", new_game_scene_path(@game), class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block no-underline" %>
      <% end %>
    </div>
  </div>
  <% if @active_scenes.empty? %>
    <p class="text-slate-400">No active scenes.</p>
  <% else %>
    <% @active_scenes.each do |scene| %>
      <%= render Shared::SceneCardComponent.new(scene: ScenePresenter.new(scene), game: @game) %>
    <% end %>
  <% end %>
</div>

<!-- Export -->
<div class="mb-10">
  <div class="flex items-center justify-between mb-4">
    <h2 class="m-0 text-xl font-semibold">Export</h2>
    <% if @export_rate_limited %>
      <button disabled class="px-5 py-2 bg-slate-300 text-slate-500 rounded text-base cursor-not-allowed inline-block" title="Export requested — check your email">Export Game</button>
    <% else %>
      <%= button_to "Export Game", game_export_path(@game), method: :post,
            class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block",
            data: { turbo_confirm: "Request an export of this game? You'll receive an email with a download link within a few minutes. The link expires after 7 days." } %>
    <% end %>
  </div>
  <p class="text-sm text-slate-500">Download a zip archive of all scenes, posts, characters, and a file manifest.</p>
</div>

<!-- Game Files -->
<div class="mb-10">
  <div class="flex items-center justify-between mb-4">
    <h2 class="m-0 text-xl font-semibold">Game Files</h2>
    <% if @is_gm %>
      <%= link_to "Manage Files", game_game_files_path(@game), class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block no-underline" %>
    <% else %>
      <%= link_to "View Files", game_game_files_path(@game), class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block no-underline" %>
    <% end %>
  </div>
  <% if @game_files.empty? %>
    <p class="text-slate-400 text-sm">No files uploaded yet.</p>
  <% else %>
    <%= render Shared::GalleryComponent.new(game_files: @game_files.to_a, game: @game, is_gm: @is_gm) %>
  <% end %>
</div>
