<nav style="font-size:0.85rem; margin-bottom:1rem; color:#64748b;">
  <%= link_to "Games", root_path %> &rsaquo;
  <%= @game.name %>
</nav>

<div class="flex items-center justify-between mb-4">
  <h1><%= @game.name %></h1>
  <% if @is_gm %>
    <%= link_to "Manage Players", game_player_management_path(@game), class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block no-underline" %>
    <%= button_to @game.sheets_hidden? ? "Show Character Sheets" : "Hide Character Sheets",
        toggle_sheets_hidden_game_path(@game), method: :patch, class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block no-underline" %>
  <% end %>
</div>
<% if @game.description.present? %>
  <p><%= @game.description %></p>
<% end %>

<!-- Character Roster -->
<div class="mb-10">
  <div class="flex items-center justify-between mb-4">
    <h2 class="m-0 text-xl font-semibold">Characters</h2>
    <%= link_to "New Character", new_game_character_path(@game), class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block no-underline" %>
  </div>
  <% if @characters.empty? %>
    <p class="text-slate-400">No characters yet.</p>
  <% else %>
    <div class="flex flex-wrap gap-3">
      <% @characters.each do |character| %>
        <div class="bg-white border border-slate-200 rounded-lg flex-1 min-w-40 max-w-64 p-3">
          <div class="font-semibold">
            <%= link_to character.name, game_character_path(@game, character) %>
          </div>
          <div class="text-xs text-slate-500 mt-0.5">
            <%= character.user.display_name || character.user.email %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<!-- Active Scenes -->
<div class="mb-10">
  <div class="flex items-center justify-between mb-4">
    <h2 class="m-0 text-xl font-semibold">Active Scenes</h2>
    <div class="flex gap-2">
      <%= link_to "All Scenes", game_scenes_path(@game), class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block no-underline" %>
      <% if @is_gm %>
        <%= link_to "New Scene", new_game_scene_path(@game), class: "px-5 py-2 bg-blue-600 text-white rounded text-base cursor-pointer hover:bg-blue-700 inline-block no-underline" %>
      <% end %>
    </div>
  </div>
  <% if @active_scenes.empty? %>
    <p class="text-slate-400">No active scenes.</p>
  <% else %>
    <% @active_scenes.each do |scene| %>
      <%= render "scenes/scene_card", scene: scene, game: @game %>
    <% end %>
  <% end %>
</div>

<!-- Game Files -->
<div class="mb-10">
  <div class="flex items-center justify-between mb-4">
    <h2 class="m-0 text-xl font-semibold">Game Files</h2>
    <% if @is_gm %>
      <%= link_to "Manage Files", game_game_files_path(@game), class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block no-underline" %>
    <% else %>
      <%= link_to "View Files", game_game_files_path(@game), class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block no-underline" %>
    <% end %>
  </div>
  <% if @game_files.empty? %>
    <p class="text-slate-400 text-sm">No files uploaded yet.</p>
  <% else %>
    <%= render "game_files/gallery", game_files: @game_files, game: @game, is_gm: @is_gm %>
  <% end %>
</div>
