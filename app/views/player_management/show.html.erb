<nav style="font-size:0.85rem; margin-bottom:1rem; color:#64748b;">
  <%= link_to "Games", root_path %> &rsaquo;
  <%= link_to @game.name, game_path(@game) %> &rsaquo;
  Manage Players
</nav>

<h1>Manage Players — <%= @game.name %></h1>

<!-- Invite Player -->
<div class="mb-10">
  <div class="flex items-center justify-between mb-4"><h2>Invite a Player</h2></div>
  <%= form_with url: game_player_management_invitations_path(@game), method: :post do |f| %>
    <div class="flex gap-2 items-end flex-wrap">
      <div class="mb-0 flex-1 min-w-52">
        <label class="block font-medium mb-1 text-sm">Email address</label>
        <input type="email" name="invitation[email]" placeholder="player@example.com" class="w-full px-3 py-2 border border-slate-300 rounded text-base">
      </div>
      <button type="submit" class="px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block no-underline">Send Invitation</button>
    </div>
  <% end %>
</div>

<!-- Current Players -->
<div class="mb-10">
  <div class="flex items-center justify-between mb-4"><h2>Current Players</h2></div>
  <div class="overflow-x-auto">
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Role</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @members.each do |member| %>
          <tr data-member-id="<%= member.user_id %>">
            <td><%= UserPresenter.new(member.user).display_name_or_email %></td>
            <td><%= member.user.email %></td>
            <td><span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold <%= member.game_master? ? 'bg-blue-100 text-blue-700' : 'bg-green-100 text-green-800' %>"><%= member.game_master? ? "GM" : "Player" %></span></td>
            <td><span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold <%= member.removed? ? 'bg-yellow-100 text-yellow-800' : 'bg-green-100 text-green-800' %>"><%= member.status.capitalize %></span></td>
            <td>
              <% unless member.game_master? %>
                <% if member.active? %>
                  <%= form_with url: game_player_management_game_member_path(@game, member), method: :patch, style: "display:inline;" do |f| %>
                    <%= f.hidden_field :status, value: "removed" %>
                    <%= f.submit "Remove", class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block no-underline text-xs px-2 py-1",
                        data: { confirm: "Remove this player? They will keep read-only access." } %>
                  <% end %>
                  <%= form_with url: game_player_management_game_member_path(@game, member), method: :patch, style: "display:inline;" do |f| %>
                    <%= f.hidden_field :status, value: "banned" %>
                    <%= f.submit "Ban", class: "px-5 py-2 bg-white text-red-600 border border-red-200 rounded text-base cursor-pointer hover:bg-red-50 inline-block no-underline text-xs px-2 py-1",
                        data: { confirm: "Ban this player? This will permanently revoke all access." } %>
                  <% end %>
                <% elsif member.removed? %>
                  <%= form_with url: game_player_management_game_member_path(@game, member), method: :patch, style: "display:inline;" do |f| %>
                    <%= f.hidden_field :status, value: "active" %>
                    <%= f.submit "Reinstate", class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block no-underline text-xs px-2 py-1" %>
                  <% end %>
                <% end %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<!-- Pending Invitations -->
<% if @pending_invitations.any? %>
  <div class="mb-10">
    <div class="flex items-center justify-between mb-4"><h2>Pending Invitations</h2></div>
    <div class="overflow-x-auto">
      <table>
        <thead>
          <tr>
            <th>Email</th>
            <th>Sent</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @pending_invitations.each do |inv| %>
            <tr>
              <td><%= inv.email %></td>
              <td><%= time_ago_in_words(inv.created_at) %> ago</td>
              <td>
                <%= form_with url: game_player_management_invitation_path(@game, inv), method: :delete, style: "display:inline;" do |f| %>
                  <%= f.submit "Cancel", class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block no-underline text-xs px-2 py-1" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>
