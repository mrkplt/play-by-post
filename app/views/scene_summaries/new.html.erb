<%= render(Ui::BreadcrumbComponent.new) do %>
  <%= link_to "Games", root_path %> &rsaquo;
  <%= link_to @game.name, game_path(@game) %> &rsaquo;
  <%= link_to @scene.title, game_scene_path(@game, @scene) %> &rsaquo;
  New Summary
<% end %>

<div class="max-w-2xl">
  <h1 class="mb-6">Write Scene Summary</h1>

  <div class="bg-white border border-slate-200 rounded-lg p-5">
    <%= form_with model: @summary, url: game_scene_scene_summary_path(@game, @scene), local: true do |f| %>
      <% if @summary.errors.any? %>
        <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded text-red-800 text-sm">
          <strong><%= pluralize(@summary.errors.count, "error") %>:</strong>
          <ul class="mt-2 list-disc list-inside">
            <% @summary.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-4">
        <%= f.label :body, "Summary", class: "block font-medium mb-1 text-sm" %>
        <%= f.text_area :body, rows: 10,
            placeholder: "Write a narrative summary of this scene...",
            class: "w-full px-3 py-2 border border-slate-300 rounded text-base font-mono text-sm" %>
        <p class="text-xs text-slate-400 mt-1">Markdown is supported.</p>
      </div>

      <div class="flex gap-2">
        <%= f.submit "Save Summary",
            class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600" %>
        <%= link_to "Cancel", game_scene_path(@game, @scene),
            class: "px-5 py-2 border border-slate-300 text-slate-700 rounded text-base cursor-pointer hover:bg-slate-50 inline-block no-underline" %>
      </div>
    <% end %>
  </div>
</div>
