<h1>Edit — <%= @character.name %></h1>

<%= form_with model: [@game, @character] do |f| %>
  <div class="field">
    <%= f.label :name %>
    <%= f.text_field :name %>
  </div>

  <div class="field">
    <%= f.label :content, "Sheet" %>
    <%= f.text_area :content, rows: 15, class: "character-sheet" %>
  </div>

  <div class="field">
    <label style="font-weight:normal; cursor:pointer;">
      <%= f.check_box :hidden %> Hide from other players
    </label>
  </div>

  <%= f.submit "Save", class: "btn" %>
  <%= link_to "Cancel", game_character_path(@game, @character), class: "btn btn--secondary" %>
<% end %>

<% if @game.game_master?(current_user) %>
  <div style="margin-top:1.5rem; padding-top:1rem; border-top:1px solid #f1f5f9;">
    <% if @character.archived? %>
      <%= button_to "Restore character", restore_game_character_path(@game, @character),
          method: :patch, class: "btn btn--secondary" %>
    <% else %>
      <%= button_to "Archive character", archive_game_character_path(@game, @character),
          method: :patch, class: "btn btn--secondary" %>
    <% end %>
  </div>
<% end %>
