<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Play By Post" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <%= render "layouts/navbar" %>
    <main>
      <% if notice.present? %>
        <p class="flash flash--notice"><%= notice %></p>
      <% end %>
      <% if alert.present? %>
        <p class="flash flash--alert"><%= alert %></p>
      <% end %>
      <%= yield %>
    </main>
  <script>
    function applyLocalTimes() {
      document.querySelectorAll("time[data-local-time]").forEach(function(el) {
        var d = new Date(el.dataset.localTime);
        el.textContent = d.toLocaleString(undefined, {
          month: "short", day: "numeric", year: "numeric",
          hour: "numeric", minute: "2-digit"
        });
      });
    }
    document.addEventListener("DOMContentLoaded", applyLocalTimes);
    document.addEventListener("turbo:render", applyLocalTimes);
  </script>
  </body>
</html>
