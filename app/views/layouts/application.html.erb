<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Play By Post" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <div data-controller="sidebar">
      <!-- Mobile hamburger -->
      <button data-action="click->sidebar#open"
              data-sidebar-target="toggle"
              class="md:hidden fixed top-4 left-4 z-50 bg-[#2b2d31] text-[#cdd1d9] border border-[#3d3f45] rounded px-3 py-2 text-lg cursor-pointer"
              aria-label="Open navigation">
        &#9776;
      </button>

      <!-- Backdrop -->
      <div class="sidebar-backdrop md:hidden"
           hidden
           data-sidebar-target="backdrop"
           data-action="click->sidebar#close"></div>

      <!-- Sidebar -->
      <aside class="sidebar" data-sidebar-target="sidebar">
        <%= render Shared::SidebarComponent.new(current_user: (current_user if user_signed_in?)) %>
      </aside>

      <!-- Main -->
      <div class="main-with-sidebar">
        <main class="content-area">
          <% if notice.present? %>
            <p class="px-4 py-3 rounded mb-4 text-sm bg-green-100 text-green-800"><%= notice %></p>
          <% end %>
          <% if alert.present? %>
            <p class="px-4 py-3 rounded mb-4 text-sm bg-red-50 text-red-800"><%= alert %></p>
          <% end %>
          <%= yield %>
        </main>
      </div>
    </div>
  <script>
    function applyLocalTimes() {
      document.querySelectorAll("time[data-local-time]").forEach(function(el) {
        var d = new Date(el.dataset.localTime);
        el.textContent = d.toLocaleString(undefined, {
          month: "short", day: "numeric", year: "numeric",
          hour: "numeric", minute: "2-digit"
        });
      });
    }
    document.addEventListener("DOMContentLoaded", applyLocalTimes);
    document.addEventListener("turbo:render", applyLocalTimes);
  </script>
  </body>
</html>
