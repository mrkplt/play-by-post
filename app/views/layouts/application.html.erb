<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Play By Post" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <div data-controller="sidebar">
      <% if user_signed_in? %>
        <%= render Shared::NavShellComponent.new(current_user: current_user) %>
      <% end %>

      <!-- Main -->
      <div class="<%= user_signed_in? ? 'main-with-sidebar' : '' %>">
        <main class="content-area">
          <% if notice.present? %>
            <p class="px-4 py-3 rounded mb-4 text-sm bg-green-100 text-green-800"><%= notice %></p>
          <% end %>
          <% if alert.present? %>
            <p class="px-4 py-3 rounded mb-4 text-sm bg-red-50 text-red-800"><%= alert %></p>
          <% end %>
          <%= yield %>
        </main>
      </div>
    </div>
  <script>
    function applyLocalTimes() {
      document.querySelectorAll("time[data-local-time]").forEach(function(el) {
        var d = new Date(el.dataset.localTime);
        el.textContent = d.toLocaleString(undefined, {
          month: "short", day: "numeric", year: "numeric",
          hour: "numeric", minute: "2-digit"
        });
      });
    }
    document.addEventListener("DOMContentLoaded", applyLocalTimes);
    document.addEventListener("turbo:render", applyLocalTimes);
  </script>
  </body>
</html>
