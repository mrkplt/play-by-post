<nav style="font-size:0.85rem; margin-bottom:1rem; color:#64748b;">
  <%= link_to "Games", root_path %> &rsaquo;
  <%= link_to @game.name, game_path(@game) %> &rsaquo;
  <%= @scene.title %>
</nav>

<div class="card">
  <div style="display:flex; justify-content:space-between; align-items:flex-start;">
    <h1 style="margin:0 0 0.5rem; font-size:1.4rem;"><%= @scene.title %></h1>
    <div style="display:flex; gap:0.4rem;">
      <% if @scene.private? %>
        <span class="badge badge--yellow">Private</span>
      <% end %>
      <% if @scene.resolved? %>
        <span class="badge badge--gray">Resolved</span>
      <% end %>
    </div>
  </div>

  <% if @scene.parent_scene.present? %>
    <p style="font-size:0.85rem; color:#64748b; margin:0 0 0.5rem;">
      ↳ Continues from <%= link_to @scene.parent_scene.title, game_scene_path(@game, @scene.parent_scene) %>
    </p>
  <% end %>

  <p style="font-size:0.85rem; color:#64748b; margin:0 0 0.75rem;">
    Participants: <%= @scene.users.map { |u| u.display_name || u.email }.join(", ") %>
  </p>

  <% if @scene.description.present? %>
    <div style="border-top:1px solid #f1f5f9; padding-top:0.75rem;">
      <%= simple_format(@scene.description) %>
    </div>
  <% end %>

  <% if @scene.resolved? && @scene.resolution.present? %>
    <div style="background:#f0fdf4; border:1px solid #bbf7d0; border-radius:4px; padding:0.75rem; margin-top:0.75rem;">
      <strong>Resolution:</strong> <%= @scene.resolution %>
    </div>
  <% end %>
</div>

<!-- Scene Toolbar -->
<% if !@scene.resolved? %>
  <div style="display:flex; gap:0.5rem; margin-bottom:1.5rem; flex-wrap:wrap;">
    <%= link_to "Quick Scene", new_game_scene_path(@game, quick: true, parent_scene_id: @scene.id), class: "btn btn--secondary" %>
    <%= link_to "New Scene", new_game_scene_path(@game, parent_scene_id: @scene.id), class: "btn btn--secondary" %>
    <% if @is_participant || @is_gm %>
      <%= link_to "Edit Participants", edit_game_scene_participants_path(@game, @scene), class: "btn btn--secondary" %>
    <% end %>
    <%= button_to @is_muted ? "Unmute" : "Mute",
        toggle_notification_preference_game_scene_path(@game, @scene),
        method: :post, class: "btn btn--secondary" %>
    <% if @is_gm %>
      <button class="btn btn--danger" onclick="document.getElementById('resolve-form').style.display='block'; this.style.display='none'">
        End Scene
      </button>
    <% end %>
  </div>

  <% if @is_gm %>
    <div id="resolve-form" style="display:none;" class="card">
      <%= form_with url: resolve_game_scene_path(@game, @scene), method: :patch do |f| %>
        <h3 style="margin-top:0;">End this scene</h3>
        <div class="field">
          <%= f.label :resolution, "Outcome (optional)" %>
          <%= f.text_area :resolution, rows: 3, placeholder: "What happened? What was gained or lost?" %>
        </div>
        <%= f.submit "Confirm — End Scene", class: "btn btn--danger" %>
      <% end %>
    </div>
  <% end %>
<% end %>

<!-- Post Thread -->
<div id="posts">
  <% if @posts.empty? %>
    <p style="color:#94a3b8;">No posts yet. Be the first!</p>
  <% else %>
    <div data-controller="ooc-filter">
      <div style="margin-bottom:1rem;">
        <label style="font-size:0.85rem; cursor:pointer;">
          <input type="checkbox" data-action="change->ooc-filter#toggle"> Hide OOC posts
        </label>
      </div>
      <% @posts.each do |post| %>
        <%= render "posts/post_item", post: post, game: @game, scene: @scene %>
      <% end %>
    </div>
  <% end %>
</div>

<!-- Post Composer -->
<% if (@is_participant || @is_gm) && !@scene.resolved? && @game.member_for(current_user)&.active? %>
  <div id="post_composer" class="card" style="margin-top:1.5rem;">
    <%= render "posts/composer", post: @post, scene: @scene, game: @game %>
  </div>
<% end %>
