<% quick = params[:quick].present? %>

<h1><%= quick ? "Quick Scene" : "New Scene" %></h1>

<%= form_with model: [@game, @scene], multipart: true do |f| %>
  <% if f.object.errors.any? %>
    <div class="px-4 py-3 rounded mb-4 text-sm bg-red-50 text-red-800">
      <% f.object.errors.full_messages.each do |msg| %>
        <div><%= msg %></div>
      <% end %>
    </div>
  <% end %>

  <div class="mb-4">
    <%= f.label :title, "Title (optional — defaults to date/time)", class: "block font-medium mb-1 text-sm" %>
    <%= f.text_field :title, maxlength: 200, autofocus: true, class: "w-full px-3 py-2 border border-slate-300 rounded text-base" %>
  </div>

  <% unless quick %>
    <div class="mb-4">
      <label class="block font-medium mb-1 text-sm">Participants</label>
      <p class="text-sm text-slate-500 mb-2">Select characters to include. The GM is always included automatically.</p>
      <% @players_with_characters.each do |user, characters| %>
        <div class="mb-3">
          <div class="text-sm font-semibold text-slate-700 mb-1">
            <%= user.display_name || user.email %>
          </div>
          <% if characters.empty? %>
            <div class="text-sm text-slate-400 pl-4">No active characters</div>
          <% else %>
            <% characters.each do |character| %>
              <label class="block font-normal mb-0.5 pl-4">
                <input type="checkbox" name="character_ids[]" value="<%= character.id %>"
                  <%= "checked" if params[:character_ids]&.include?(character.id.to_s) || @scene.scene_participants.map(&:character_id).include?(character.id) %>>
                <%= character.name %>
              </label>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="mb-4">
      <%= f.label :parent_scene_id, "Parent scene (optional)", class: "block font-medium mb-1 text-sm" %>
      <% parent_options = @parent_scene_options.map { |s| [s.resolved? ? "#{s.title} (Resolved)" : s.title, s.id] } %>
      <%= f.select :parent_scene_id, parent_options,
          { include_blank: "— none —", selected: params[:parent_scene_id] }, class: "w-full px-3 py-2 border border-slate-300 rounded text-base" %>
    </div>

    <div class="mb-4">
      <label class="font-normal cursor-pointer">
        <%= f.check_box :private %> Private scene
      </label>
    </div>

    <div class="mb-4">
      <%= f.label :image, "Scene image (optional)", class: "block font-medium mb-1 text-sm" %>
      <%= f.file_field :image, accept: "image/jpeg,image/png,image/gif,image/webp", class: "w-full px-3 py-2 border border-slate-300 rounded text-base" %>
      <p class="text-xs text-slate-400 mt-1 mb-0">JPEG, PNG, GIF, or WebP. Max 10MB.</p>
    </div>
  <% else %>
    <%= f.hidden_field :parent_scene_id, value: params[:parent_scene_id] %>
    <% Array(params[:character_ids]).each do |cid| %>
      <input type="hidden" name="character_ids[]" value="<%= cid %>">
    <% end %>
  <% end %>

  <%= f.submit quick ? "Create Quick Scene" : "Create Scene", class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block no-underline" %>
  <%= link_to "Cancel", params[:parent_scene_id].present? ? game_scene_path(@game, params[:parent_scene_id]) : game_path(@game), class: "px-5 py-2 bg-slate-500 text-white rounded text-base cursor-pointer hover:bg-slate-600 inline-block no-underline" %>
<% end %>
