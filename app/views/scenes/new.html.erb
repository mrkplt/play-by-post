<% quick = params[:quick].present? %>

<h1><%= quick ? "Quick Scene" : "New Scene" %></h1>

<%= form_with model: [@game, @scene] do |f| %>
  <% if f.object.errors.any? %>
    <div class="flash flash--alert">
      <% f.object.errors.full_messages.each do |msg| %>
        <div><%= msg %></div>
      <% end %>
    </div>
  <% end %>

  <div class="field">
    <%= f.label :title %>
    <%= f.text_field :title, maxlength: 200, autofocus: true %>
  </div>

  <div class="field">
    <%= f.label :description, "Description (optional)" %>
    <%= f.text_area :description, rows: 4 %>
  </div>

  <% unless quick %>
    <div class="field">
      <label>Participants</label>
      <p style="font-size:0.85rem; color:#64748b; margin:0.25rem 0 0.5rem;">Select characters to include. The GM is always included automatically.</p>
      <% @players_with_characters.each do |user, characters| %>
        <div style="margin-bottom:0.75rem;">
          <div style="font-size:0.85rem; font-weight:600; color:#475569; margin-bottom:0.25rem;">
            <%= user.display_name || user.email %>
          </div>
          <% if characters.empty? %>
            <div style="font-size:0.85rem; color:#94a3b8; padding-left:1rem;">No active characters</div>
          <% else %>
            <% characters.each do |character| %>
              <label style="display:block; font-weight:normal; margin-bottom:0.2rem; padding-left:1rem;">
                <input type="checkbox" name="character_ids[]" value="<%= character.id %>"
                  <%= "checked" if params[:character_ids]&.include?(character.id.to_s) || @scene.scene_participants.map(&:character_id).include?(character.id) %>>
                <%= character.name %>
              </label>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="field">
      <%= f.label :parent_scene_id, "Parent scene (optional)" %>
      <%= f.select :parent_scene_id,
          @game.scenes.order(:title).map { |s| [s.title, s.id] },
          { include_blank: "— none —", selected: params[:parent_scene_id] } %>
    </div>

    <div class="field">
      <label style="font-weight:normal; cursor:pointer;">
        <%= f.check_box :private %> Private scene
      </label>
    </div>
  <% else %>
    <%= f.hidden_field :parent_scene_id, value: params[:parent_scene_id] %>
    <% Array(params[:character_ids]).each do |cid| %>
      <input type="hidden" name="character_ids[]" value="<%= cid %>">
    <% end %>
  <% end %>

  <%= f.submit quick ? "Create Quick Scene" : "Create Scene", class: "btn" %>
  <%= link_to "Cancel", params[:parent_scene_id].present? ? game_scene_path(@game, params[:parent_scene_id]) : game_path(@game), class: "btn btn--secondary" %>
<% end %>
