<%# Recursive tree node for DAG display.
     Expects: node (hash with :scene, :children), game, depth %>

<% scene = node[:scene] %>
<% children = node[:children] %>
<% is_active = !scene.resolved? %>

<div class="mb-0.5" style="margin-left:<%= depth * 1.5 %>rem;">
  <div class="flex items-center gap-2 px-2 py-1 rounded <%= is_active ? 'font-semibold' : 'text-slate-500' %>">
    <% if depth > 0 %>
      <span class="text-slate-400 font-mono shrink-0">└─</span>
    <% end %>
    <span class="whitespace-nowrap">
      <%= link_to scene.title, game_scene_path(game, scene), class: is_active ? '' : 'text-slate-500' %>
    </span>
    <% if is_active %>
      <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-800">Active</span>
    <% else %>
      <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-slate-100 text-slate-600">Resolved</span>
    <% end %>
    <% if scene.private? %>
      <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-yellow-100 text-yellow-800">Private</span>
    <% end %>
    <span class="text-xs text-slate-400 ml-auto whitespace-nowrap">
      <%= scene.created_at.strftime("%b %-d, %Y %l:%M%P") %>
    </span>
  </div>

  <% children.each do |child_node| %>
    <%= render "scenes/tree_node", node: child_node, game: game, depth: depth + 1 %>
  <% end %>
</div>
