  def multiple?; end

  # Returns page this file chooser belongs to.
  #
  # pkg:gem/playwright-ruby-client#lib/playwright_api/file_chooser.rb:27
  def page; end

  # Sets the value of the file input this chooser is associated with. If some of the `filePaths` are relative paths, then
  # they are resolved relative to the current working directory. For empty array, clears the selected files.
  #
  # pkg:gem/playwright-ruby-client#lib/playwright_api/file_chooser.rb:34
  def set_files(files, noWaitAfter: T.unsafe(nil), timeout: T.unsafe(nil)); end
end

