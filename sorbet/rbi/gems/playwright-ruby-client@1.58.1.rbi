  # -- inherited from EventEmitter --
  #
  # pkg:gem/playwright-ruby-client#lib/playwright_api/dialog.rb:79
  def on(event, callback); end

  # -- inherited from EventEmitter --
  #
  # pkg:gem/playwright-ruby-client#lib/playwright_api/dialog.rb:73
