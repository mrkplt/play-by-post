  # pkg:gem/playwright-ruby-client#lib/playwright_api/file_chooser.rb:37
  def files=(files, noWaitAfter: T.unsafe(nil), timeout: T.unsafe(nil)); end

  # Returns whether this file chooser accepts multiple files.
