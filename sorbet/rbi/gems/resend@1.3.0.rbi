# This class is responsible for making the appropriate HTTP calls
# and raising the specific errors based on the response.
#
# pkg:gem/resend#lib/resend/request.rb:6
class Resend::Request
  # @return [Request] a new instance of Request
  #
  # pkg:gem/resend#lib/resend/request.rb:11
  def initialize(path = T.unsafe(nil), body = T.unsafe(nil), verb = T.unsafe(nil), options: T.unsafe(nil)); end

  # Returns the value of attribute body.
  #
  # pkg:gem/resend#lib/resend/request.rb:9
  def body; end

  # Sets the attribute body
  #
  # @param value the value to set the attribute body to.
  #
  # pkg:gem/resend#lib/resend/request.rb:9
  def body=(_arg0); end

  # @raise [error_class]
  #
  # pkg:gem/resend#lib/resend/request.rb:43
  def handle_error!(data, resp = T.unsafe(nil)); end

  # Returns the value of attribute options.
  #
  # pkg:gem/resend#lib/resend/request.rb:9
  def options; end

  # Sets the attribute options
  #
  # @param value the value to set the attribute options to.
  #
  # pkg:gem/resend#lib/resend/request.rb:9
  def options=(_arg0); end

  # Performs the HTTP call
  #
  # pkg:gem/resend#lib/resend/request.rb:32
  def perform; end

  # Returns the value of attribute verb.
  #
  # pkg:gem/resend#lib/resend/request.rb:9
  def verb; end

  # Sets the attribute verb
  #
  # @param value the value to set the attribute verb to.
  #
  # pkg:gem/resend#lib/resend/request.rb:9
  def verb=(_arg0); end

  private

  # pkg:gem/resend#lib/resend/request.rb:55
  def build_request_options; end

  # pkg:gem/resend#lib/resend/request.rb:101
  def check_json!(resp); end

  # @return [Boolean]
  #
  # pkg:gem/resend#lib/resend/request.rb:80
  def error_response?(resp); end

  # Extract and normalize headers from the HTTParty response
  #
  # pkg:gem/resend#lib/resend/request.rb:112
  def extract_headers(resp); end

  # @return [Boolean]
  #
  # pkg:gem/resend#lib/resend/request.rb:67
  def get_request_with_query?; end

  # pkg:gem/resend#lib/resend/request.rb:71
  def process_response(resp); end

  # pkg:gem/resend#lib/resend/request.rb:93
  def set_batch_validation; end

  # pkg:gem/resend#lib/resend/request.rb:84
  def set_idempotency_key; end
end

# pkg:gem/resend#lib/resend/request.rb:7
Resend::Request::BASE_URL = T.let(T.unsafe(nil), String)

# Response wrapper that maintains backwards compatibility while exposing headers
#
# This class wraps API responses and behaves like a Hash for backwards compatibility,
# while also providing access to response headers via the #headers method.
#
# @example Accessing response headers
#   response = Resend::Emails.send(params)
#   response.headers  # => {"content-type" => "application/json", ...}
#   response.headers['x-ratelimit-remaining']  # => "50"
# @example Backwards compatible hash access
#   response = Resend::Emails.send(params)
#   response[:id]  # => "49a3999c-0ce1-4ea6-ab68-afcd6dc2e794"
#
# pkg:gem/resend#lib/resend/response.rb:17
class Resend::Response
  include ::Enumerable

  # @param data [Hash] The response data
  # @param headers [Hash, HTTParty::Response] The response headers
  # @return [Response] a new instance of Response
  #
  # pkg:gem/resend#lib/resend/response.rb:22
  def initialize(data, headers); end

  # Hash-like access via []
  #
  # @param key [Symbol, String] The key to access
  # @return [Object] The value at the key
  #
  # pkg:gem/resend#lib/resend/response.rb:34
  def [](key); end

  # Hash-like assignment via []=
  #
  # @param key [Symbol, String] The key to set
  # @param value [Object] The value to set
  #
  # pkg:gem/resend#lib/resend/response.rb:41
  def []=(key, value); end

  # Dig into nested hash structure
  #
  # @param keys [Array<Symbol, String>] Keys to dig through
  # @return [Object] The value at the nested key path
  #
  # pkg:gem/resend#lib/resend/response.rb:48
  def dig(*keys); end

  # Enable enumeration over the data
  #
  # pkg:gem/resend#lib/resend/response.rb:82
  def each(&block); end

  # Check if response is empty
  #
  # @return [Boolean] True if data is empty
  #
  # pkg:gem/resend#lib/resend/response.rb:95
  def empty?; end

  # Check if key exists
  #
  # @param key [Symbol, String] The key to check
  # @return [Boolean] True if key exists
  #
  # pkg:gem/resend#lib/resend/response.rb:79
  def has_key?(key); end

  # Access response headers
  #
  # @return [Hash] Response headers as a hash with lowercase string keys
  #
  # pkg:gem/resend#lib/resend/response.rb:29
  def headers; end

  # String representation for debugging
  #
  # @return [String] String representation of the response
  #
  # pkg:gem/resend#lib/resend/response.rb:117
  def inspect; end

  # Check if key exists
  #
  # @param key [Symbol, String] The key to check
  # @return [Boolean] True if key exists
  #
  # pkg:gem/resend#lib/resend/response.rb:75
  def key?(key); end

  # Get all keys from the data
  #
  # @return [Array] Array of keys
  #
  # pkg:gem/resend#lib/resend/response.rb:62
  def keys; end

  # Delegate unknown methods to the underlying data hash
  #
  # pkg:gem/resend#lib/resend/response.rb:105
  def method_missing(method_name, *args, &block); end

  # Convert to plain hash
  #
  # @return [Hash] The underlying data hash
  #
  # pkg:gem/resend#lib/resend/response.rb:54
  def to_h; end

  # Convert to plain hash
  #
  # @return [Hash] The underlying data hash
  #
  # pkg:gem/resend#lib/resend/response.rb:58
  def to_hash; end

  # Transform keys in the underlying data
  #
  # @return [Resend::Response] Self for chaining
  #
  # pkg:gem/resend#lib/resend/response.rb:88
  def transform_keys!(&block); end

  # Get all values from the data
  #
  # @return [Array] Array of values
  #
  # pkg:gem/resend#lib/resend/response.rb:68
  def values; end

  private

  # Normalize headers to a simple hash with lowercase string keys
  #
  # @param headers [Hash, HTTParty::Response, nil] The headers to normalize
  # @return [Hash] Normalized headers hash
  #
  # pkg:gem/resend#lib/resend/response.rb:126
  def normalize_headers(headers); end

  # Respond to hash-like methods
  #
  # @return [Boolean]
  #
  # pkg:gem/resend#lib/resend/response.rb:100
  def respond_to_missing?(method_name, include_private = T.unsafe(nil)); end
end

