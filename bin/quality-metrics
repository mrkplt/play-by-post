#!/usr/bin/env ruby
# frozen_string_literal: true

# Collects code quality metrics (coverage, typing, mutation) and optionally
# checks them against a stored baseline. Exits non-zero if any metric
# regresses more than the allowed threshold or if changed files have
# insufficient test coverage.
#
# This script reads from artifacts produced by other tools and runs Sorbet
# type checking directly. Run test/mutation tools first:
#   1. bundle exec rspec          -> produces coverage/.last_run.json
#   2. bundle exec mutant run ... -> produces tmp/mutant_result.json (via --save flag below)
#
# The --check flag also runs `bundle exec srb tc` to verify type correctness.
#
# Usage:
#   bin/quality-metrics                      # collect and display current metrics
#   bin/quality-metrics --save               # save current metrics as the new baseline
#   bin/quality-metrics --check              # compare against baseline, fail on regression
#   bin/quality-metrics --record-mutant FILE # extract mutation score from mutant output file

require "json"
require "time"

BASELINE_PATH = File.expand_path("../quality_baseline.json", __dir__)
MUTANT_RESULT_PATH = File.expand_path("../tmp/mutant_result.json", __dir__)
SIMPLECOV_RESULTSET_PATH = File.expand_path("../coverage/.resultset.json", __dir__)
PROJECT_ROOT = File.expand_path("..", __dir__)
THRESHOLD = 5.0 # max allowed regression in percentage points
CHANGED_FILE_LINE_THRESHOLD = 80.0 # minimum line coverage for changed files
CHANGED_FILE_BRANCH_THRESHOLD = 70.0 # minimum branch coverage for changed files
REQUIRED_SORBET_SIGILS = %w[true strict strong].freeze

METRIC_KEYS = %w[line_coverage branch_coverage sorbet_typed_pct mutation_coverage].freeze

def collect_metrics
  metrics = {}

  # --- SimpleCov (line + branch coverage) ---
  simplecov_path = File.expand_path("../coverage/.last_run.json", __dir__)
  if File.exist?(simplecov_path)
    data = JSON.parse(File.read(simplecov_path))
    result = data["result"]
    metrics["line_coverage"] = result["line"]
    metrics["branch_coverage"] = result["branch"]
  else
    warn "WARNING: No SimpleCov data found. Run `bundle exec rspec` first."
  end

  # --- Sorbet (sigils excluding RBIs) ---
  spoom_output = `bundle exec spoom srb coverage 2>&1`
  total_files = spoom_output[/files excluding rbis:\s*(\d+)/, 1]&.to_i || 0

  # Parse sigils breakdown from spoom output — look for the excluding-RBIs section
  # Spoom doesn't break this down in CLI, so we use the JSON snapshot
  spoom_json_output = `bundle exec ruby -rjson -rspoom -e '
    context = Spoom::Context.new(".")
    snapshot = Spoom::Coverage.snapshot(context)
    puts JSON.generate(snapshot.sigils_excluding_rbis)
  ' 2>/dev/null`

  begin
    sigils = JSON.parse(spoom_json_output)
    typed_files = (sigils["true"] || 0) + (sigils["strict"] || 0) + (sigils["strong"] || 0)
    metrics["sorbet_typed_pct"] = total_files > 0 ? (typed_files.to_f / total_files * 100).round(2) : 0.0
  rescue JSON::ParserError
    warn "WARNING: Could not parse Sorbet coverage data."
  end

  # --- Mutant (mutation coverage) ---
  if File.exist?(MUTANT_RESULT_PATH)
    mutant_data = JSON.parse(File.read(MUTANT_RESULT_PATH))
    metrics["mutation_coverage"] = mutant_data["coverage"]
  else
    warn "WARNING: No mutant results found at #{MUTANT_RESULT_PATH}."
    warn "         Run mutant and pipe output through: bin/quality-metrics --record-mutant"
  end

  metrics
end

def record_mutant(output_file)
  content = File.read(output_file)
  coverage_match = content[/Coverage:\s*([\d.]+)%/, 1]
  mutations_match = content[/Mutations:\s*(\d+)/, 1]
  kills_match = content[/Kills:\s*(\d+)/, 1]
  alive_match = content[/Alive:\s*(\d+)/, 1]

  result = {
    "coverage" => coverage_match&.to_f,
    "mutations" => mutations_match&.to_i,
    "kills" => kills_match&.to_i,
    "alive" => alive_match&.to_i,
    "recorded_at" => Time.now.iso8601
  }

  FileUtils.mkdir_p(File.dirname(MUTANT_RESULT_PATH))
  File.write(MUTANT_RESULT_PATH, JSON.pretty_generate(result))
  puts "Mutant results saved: coverage=#{result['coverage']}% (#{result['kills']}/#{result['mutations']} killed, #{result['alive']} alive)"
end

def load_baseline
  return nil unless File.exist?(BASELINE_PATH)
  JSON.parse(File.read(BASELINE_PATH))
end

def save_baseline(metrics)
  File.write(BASELINE_PATH, JSON.pretty_generate(metrics.merge("saved_at" => Time.now.iso8601)))
  puts "Baseline saved to #{BASELINE_PATH}"
end

def display_metrics(metrics)
  puts "=== Code Quality Metrics ==="
  puts "  Line coverage:      #{fmt(metrics['line_coverage'])}" if metrics["line_coverage"]
  puts "  Branch coverage:    #{fmt(metrics['branch_coverage'])}" if metrics["branch_coverage"]
  puts "  Sorbet typed files: #{fmt(metrics['sorbet_typed_pct'])}" if metrics["sorbet_typed_pct"]
  puts "  Mutation coverage:  #{fmt(metrics['mutation_coverage'])}" if metrics["mutation_coverage"]
end

def fmt(value)
  "#{value&.round(2)}%"
end

def changed_app_files
  `git diff --name-only origin/master -- app/ lib/`.strip.split("\n")
    .select { |f| f.end_with?(".rb") }
    .select { |f| File.exist?(File.join(PROJECT_ROOT, f)) }
end

def file_coverage(lines)
  relevant = lines.compact
  return nil if relevant.empty?

  covered = relevant.count { |hits| hits > 0 }
  (covered.to_f / relevant.size * 100).round(2)
end

def branch_coverage_for_file(branches)
  return nil if branches.nil? || branches.empty?

  conditions = branches.values.flat_map(&:values)
  return nil if conditions.empty?

  covered = conditions.count { |hits| hits > 0 }
  (covered.to_f / conditions.size * 100).round(2)
end

def check_changed_file_coverage
  unless File.exist?(SIMPLECOV_RESULTSET_PATH)
    warn "WARNING: No SimpleCov resultset found. Cannot check per-file coverage."
    return []
  end

  resultset = JSON.parse(File.read(SIMPLECOV_RESULTSET_PATH))
  file_data = resultset.dig("RSpec", "coverage") || {}

  changed = changed_app_files
  return [] if changed.empty?

  puts "\n=== Changed File Coverage (line >= #{CHANGED_FILE_LINE_THRESHOLD}%, branch >= #{CHANGED_FILE_BRANCH_THRESHOLD}%) ==="
  failures = []

  changed.each do |relative_path|
    absolute_path = File.join(PROJECT_ROOT, relative_path)
    coverage = file_data[absolute_path]

    if coverage.nil?
      puts "  [FAIL] #{relative_path}: no coverage data (untested)"
      failures << "#{relative_path}: no coverage data — file is untested"
      next
    end

    line_cov = file_coverage(coverage["lines"])
    branch_cov = branch_coverage_for_file(coverage["branches"])

    line_ok = line_cov.nil? || line_cov >= CHANGED_FILE_LINE_THRESHOLD
    branch_ok = branch_cov.nil? || branch_cov >= CHANGED_FILE_BRANCH_THRESHOLD

    status = (line_ok && branch_ok) ? "OK" : "FAIL"
    parts = []
    parts << "line: #{line_cov}%" if line_cov
    parts << "branch: #{branch_cov}%" if branch_cov
    puts "  [#{status}] #{relative_path}: #{parts.join(', ')}"

    unless line_ok
      failures << "#{relative_path}: line coverage #{line_cov}% < #{CHANGED_FILE_LINE_THRESHOLD}%"
    end
    unless branch_ok
      failures << "#{relative_path}: branch coverage #{branch_cov}% < #{CHANGED_FILE_BRANCH_THRESHOLD}%"
    end
  end

  failures
end

def file_sorbet_sigil(absolute_path)
  first_line = File.foreach(absolute_path).first
  return nil unless first_line

  match = first_line[/^#\s*typed:\s*(\w+)/, 1]
  match&.downcase
end

def check_changed_file_sigils
  changed = changed_app_files
  return [] if changed.empty?

  puts "\n=== Changed File Sorbet Sigils (required: #{REQUIRED_SORBET_SIGILS.join('/')}) ==="
  failures = []

  changed.each do |relative_path|
    absolute_path = File.join(PROJECT_ROOT, relative_path)
    sigil = file_sorbet_sigil(absolute_path)
    ok = REQUIRED_SORBET_SIGILS.include?(sigil)

    status = ok ? "OK" : "FAIL"
    label = sigil || "none"
    puts "  [#{status}] #{relative_path}: typed: #{label}"

    unless ok
      failures << "#{relative_path}: Sorbet sigil is '#{label}', must be #{REQUIRED_SORBET_SIGILS.join('/')}"
    end
  end

  failures
end

def check_sorbet_tc
  puts "\n=== Sorbet Type Check ==="
  output = `bundle exec srb tc 2>&1`
  status = $?.success?

  if status
    puts "  [OK] srb tc passed with no errors"
    []
  else
    error_count = output[/Errors:\s*(\d+)/, 1] || "unknown"
    puts "  [FAIL] srb tc found #{error_count} error(s)"
    output.each_line { |line| puts "    #{line}" unless line.strip.empty? }
    ["srb tc failed with #{error_count} error(s)"]
  end
end

def check_against_baseline(metrics, baseline)
  puts "\n=== Baseline Comparison (max regression: #{THRESHOLD} points) ==="
  failures = []

  METRIC_KEYS.each do |key|
    current = metrics[key]
    previous = baseline[key]
    next if current.nil? || previous.nil?

    if key == "mutation_coverage"
      # Mutation coverage uses --since (incremental). The baseline value is a
      # minimum floor, not a regression target. Changed code must meet or
      # exceed the floor. Skip when --since found no mutations to test.
      mutant_data = File.exist?(MUTANT_RESULT_PATH) ? JSON.parse(File.read(MUTANT_RESULT_PATH)) : {}
      mutations = mutant_data["mutations"] || 0

      if mutations.zero?
        puts "  [SKIP] #{key}: no mutations in changed code"
        next
      end

      failed = current < previous
      status = failed ? "FAIL" : "OK"
      puts "  [#{status}] #{key}: #{current.round(2)}% (floor: #{previous.round(2)}%)"

      if failed
        failures << "#{key}: #{current.round(2)}% is below floor of #{previous.round(2)}%"
      end
    else
      regression = previous - current
      delta = current - previous
      symbol = delta >= 0 ? "+" : ""
      failed = regression > THRESHOLD
      status = failed ? "FAIL" : "OK"
      puts "  [#{status}] #{key}: #{previous.round(2)}% -> #{current.round(2)}% (#{symbol}#{delta.round(2)})"

      if failed
        failures << "#{key}: #{previous.round(2)}% -> #{current.round(2)}% (regressed #{regression.round(2)} points, max allowed: #{THRESHOLD})"
      end
    end
  end

  failures
end

# --- Main ---
require "fileutils"

mode = ARGV[0]

case mode
when "--save"
  metrics = collect_metrics
  display_metrics(metrics)
  save_baseline(metrics)
when "--check"
  baseline = load_baseline
  if baseline.nil?
    warn "No baseline found at #{BASELINE_PATH}. Run `bin/quality-metrics --save` first."
    exit 1
  end

  metrics = collect_metrics
  display_metrics(metrics)
  baseline_failures = check_against_baseline(metrics, baseline)
  changed_file_failures = check_changed_file_coverage
  changed_file_sigil_failures = check_changed_file_sigils

  sorbet_tc_failures = check_sorbet_tc

  failures = baseline_failures + changed_file_failures + changed_file_sigil_failures + sorbet_tc_failures

  if failures.any?
    puts "\nFAILED: Quality checks did not pass:"
    failures.each { |f| puts "  - #{f}" }
    exit 1
  else
    puts "\nAll metrics within acceptable range."
  end
when "--record-mutant"
  file = ARGV[1]
  if file.nil? || !File.exist?(file)
    warn "Usage: bin/quality-metrics --record-mutant <mutant-output-file>"
    exit 1
  end
  record_mutant(file)
else
  metrics = collect_metrics
  display_metrics(metrics)
  puts "\nCommands:"
  puts "  bin/quality-metrics --save               # save current metrics as baseline"
  puts "  bin/quality-metrics --check              # check against baseline (fails on >#{THRESHOLD}% regression)"
  puts "  bin/quality-metrics --record-mutant FILE # record mutant output for metrics"
end
