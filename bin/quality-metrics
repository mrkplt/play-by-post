#!/usr/bin/env ruby
# frozen_string_literal: true

# Collects code quality metrics (coverage, typing, mutation) and optionally
# checks them against a stored baseline. Exits non-zero if any metric
# regresses more than the allowed threshold or if changed files have
# insufficient test coverage.
#
# This script reads from artifacts produced by other tools and runs Sorbet
# type checking directly. Run test/mutation tools first:
#   1. bundle exec rspec          -> produces coverage/.last_run.json
#   2. bundle exec mutant run ... -> produces tmp/mutant_result.json (via --save flag below)
#
# The --check flag also runs `bundle exec srb tc` to verify type correctness.
#
# Usage:
#   bin/quality-metrics                      # collect and display current metrics
#   bin/quality-metrics --save               # save current metrics as the new baseline
#   bin/quality-metrics --check              # compare against baseline, fail on regression
#   bin/quality-metrics --record-mutant FILE # extract mutation score from mutant output file

require "json"
require "set"
require "time"

BASELINE_PATH = File.expand_path("../quality_baseline.json", __dir__)
MUTANT_RESULT_PATH = File.expand_path("../tmp/mutant_result.json", __dir__)
SIMPLECOV_RESULTSET_PATH = File.expand_path("../coverage/.resultset.json", __dir__)
PROJECT_ROOT = File.expand_path("..", __dir__)
THRESHOLD = 5.0 # max allowed regression in percentage points
CHANGED_FILE_LINE_THRESHOLD = 80.0 # minimum line coverage for changed files
CHANGED_FILE_BRANCH_THRESHOLD = 70.0 # minimum branch coverage for changed files
REQUIRED_SORBET_SIGILS = %w[true strict strong].freeze

METRIC_KEYS = %w[line_coverage branch_coverage sorbet_typed_pct mutation_coverage css_in_components_pct presenter_method_violations].freeze
FLOOR_METRICS = %w[mutation_coverage css_in_components_pct].freeze
# Ceiling metrics track counts where lower is better; the baseline is a maximum.
CEILING_METRICS = %w[presenter_method_violations].freeze
EXCLUDED_MODEL_BASENAMES = %w[application_record.rb current.rb].freeze

# Indicators of logic in ERB templates that belongs in presenters or component Ruby classes.
# Three patterns are detected:
#   1. Ternary in output tag:     <%= expr ? val : val %>
#      A space before ? distinguishes the ternary operator from predicate method calls.
#   2. Boolean OR fallback:       <%= a || b %>
#      Inline fallback/default logic belongs in a presenter method.
#   3. Local variable assignment: <% var = value %>
#      Data preparation in the template belongs in the component class or controller.
ERB_TERNARY_OUTPUT_RE = /<%=.*?\s\?\s.*?%>/
ERB_OR_FALLBACK_OUTPUT_RE = /<%=.*?\s\|\|\s.*?%>/
ERB_LOCAL_ASSIGN_RE = /<%[^=%#].*?\b[a-z_]\w*\s*=(?![=~>]).*?%>/
ERB_CONTROL_FLOW_RE = /\b(if|unless|while|until|for|case|when|rescue|begin|do)\b/

def erb_logic_count(content)
  count = content.scan(ERB_TERNARY_OUTPUT_RE).size
  count += content.scan(ERB_OR_FALLBACK_OUTPUT_RE).size
  content.scan(ERB_LOCAL_ASSIGN_RE) do |_|
    count += 1 unless $~[0].match?(ERB_CONTROL_FLOW_RE)
  end
  count
end

# Matches static class="..." / class='...' attribute values in ERB/HTML files.
# The character class stops at < so ERB interpolations (e.g. <%= ... %>) are
# not included in the captured value; only the static tokens around them count.
CSS_CLASS_ATTR_RE = /\bclass=["']([^"'<>\n]*)["']/

# Matches static style="..." / style='...' attribute values.
CSS_STYLE_ATTR_RE = /\bstyle=["']([^"'<>\n]*)["']/

# Count CSS statements across the given files.  Two kinds are recognised:
#   class="..." — each whitespace-separated token is one statement
#   style="..." — each semicolon-separated declaration is one statement
# Both are relevant to ViewComponent modularisation regardless of whether
# the end result is Tailwind utilities or raw inline styles.
def css_statements_in_content(content)
  count = 0
  content.scan(CSS_CLASS_ATTR_RE) { |m| count += m[0].split.size }
  content.scan(CSS_STYLE_ATTR_RE) { |m| count += m[0].split(";").count { |d| !d.strip.empty? } }
  count
end

def count_css_statements_in_files(files)
  count = 0
  files.each do |file|
    content = File.read(file, encoding: "utf-8")
    count += css_statements_in_content(content)
  rescue Encoding::InvalidByteSequenceError, Encoding::UndefinedConversionError
    # skip non-UTF-8 files
  end
  count
end

def collect_css_metrics
  view_files      = Dir.glob(File.join(PROJECT_ROOT, "app/views/**/*.html.erb"))
  component_files = Dir.glob(File.join(PROJECT_ROOT, "app/components/**/*.html.erb"))

  view_css      = count_css_statements_in_files(view_files)
  component_css = count_css_statements_in_files(component_files)
  total = view_css + component_css
  pct   = total > 0 ? (component_css.to_f / total * 100).round(2) : 0.0

  {
    "view_css_statements"       => view_css,
    "component_css_statements"  => component_css,
    "css_in_components_pct"     => pct
  }
end

# Returns the names of all explicitly declared public instance methods in a
# model file.  Stops collecting when a bare `private` or `protected` keyword
# is encountered (handles the common `private\ndef …` style used in this app).
# Class methods and `initialize` are excluded; names shorter than four
# characters are skipped to reduce false-positive matches in call-site search.
def extract_public_model_methods(file_path)
  content = File.read(file_path, encoding: "utf-8")
  methods = []
  past_private = false

  content.each_line do |line|
    stripped = line.strip
    past_private = true if stripped.match?(/\A(private|protected)(\s|\z)/)
    next if past_private

    if (m = stripped.match(/\Adef\s+([a-z_]\w*[\?!]?)/))
      name = m[1]
      next if name == "initialize" || name.length < 4
      methods << name
    end
  end

  methods.uniq
rescue Encoding::InvalidByteSequenceError, Encoding::UndefinedConversionError
  []
end

# Scans all non-model, non-spec app files for each public model method.
# A method is a *violation* when every call site found is in the presentation
# layer (app/views, app/components ERBs, app/mailers Ruby) and none appear in
# other Ruby or ERB files (controllers, presenters, jobs, services, helpers…).
# This signals that the method exists solely to serve presentation concerns and
# belongs in a presenter instead.
#
# Returns a hash whose keys are:
#   "presenter_method_violations"  — integer count (stored in baseline)
#   "_presenter_method_total"      — total public model methods (display only)
#   "_presenter_violation_details" — array of violation hashes (display only)
def collect_presenter_violations
  model_files = Dir.glob(File.join(PROJECT_ROOT, "app/models/**/*.rb")).reject do |f|
    EXCLUDED_MODEL_BASENAMES.include?(File.basename(f))
  end

  # Presentation layer: view ERBs, component ERBs, mailer Ruby files.
  view_mailer_set = Set.new(
    Dir.glob(File.join(PROJECT_ROOT, "app/views/**/*.erb")) +
    Dir.glob(File.join(PROJECT_ROOT, "app/components/**/*.erb")) +
    Dir.glob(File.join(PROJECT_ROOT, "app/mailers/**/*.rb"))
  )

  model_file_set = Set.new(model_files)

  # All non-model app files (Ruby + ERB); specs are excluded from call-site
  # search because test coverage should not count as a production call site.
  search_files = Dir.glob("#{PROJECT_ROOT}/app/**/*.{rb,erb}").reject do |f|
    model_file_set.include?(f)
  end

  # Pre-read every search file once to avoid repeated disk I/O per method.
  file_contents = {}
  search_files.each do |f|
    file_contents[f] = File.read(f, encoding: "utf-8")
  rescue Encoding::InvalidByteSequenceError, Encoding::UndefinedConversionError
    file_contents[f] = ""
  end

  violations = []
  total_methods = 0

  model_files.sort.each do |model_file|
    methods = extract_public_model_methods(model_file)
    total_methods += methods.size
    model_class = File.basename(model_file, ".rb").split("_").map(&:capitalize).join

    methods.each do |method_name|
      # Use a lookahead instead of a trailing \b so that method names ending
      # with ? or ! (non-word chars) are also matched correctly.
      pattern = /\b#{Regexp.escape(method_name)}(?=\W|\z)/
      view_mailer_sites = []
      other_sites = []

      file_contents.each do |file, content|
        next unless content.match?(pattern)

        rel = file.delete_prefix("#{PROJECT_ROOT}/")
        if view_mailer_set.include?(file)
          view_mailer_sites << rel
        else
          other_sites << rel
        end
      end

      # Only flag if the method has at least one view/mailer call site and
      # zero call sites in any other part of the application.
      next unless view_mailer_sites.any? && other_sites.empty?

      violations << {
        "model" => model_class,
        "method" => method_name,
        "sites" => view_mailer_sites
      }
    end
  end

  {
    "presenter_method_violations" => violations.size,
    "_presenter_method_total" => total_methods,
    "_presenter_violation_details" => violations
  }
end

def collect_metrics
  metrics = {}

  # --- SimpleCov (line + branch coverage) ---
  simplecov_path = File.expand_path("../coverage/.last_run.json", __dir__)
  if File.exist?(simplecov_path)
    data = JSON.parse(File.read(simplecov_path))
    result = data["result"]
    metrics["line_coverage"] = result["line"]
    metrics["branch_coverage"] = result["branch"]
  else
    warn "WARNING: No SimpleCov data found. Run `bundle exec rspec` first."
  end

  # --- Sorbet (sigils excluding RBIs) ---
  spoom_output = `bundle exec spoom srb coverage 2>&1`
  total_files = spoom_output[/files excluding rbis:\s*(\d+)/, 1]&.to_i || 0

  # Parse sigils breakdown from spoom output — look for the excluding-RBIs section
  # Spoom doesn't break this down in CLI, so we use the JSON snapshot
  spoom_json_output = `bundle exec ruby -rjson -rspoom -e '
    context = Spoom::Context.new(".")
    snapshot = Spoom::Coverage.snapshot(context)
    puts JSON.generate(snapshot.sigils_excluding_rbis)
  ' 2>/dev/null`

  begin
    sigils = JSON.parse(spoom_json_output)
    typed_files = (sigils["true"] || 0) + (sigils["strict"] || 0) + (sigils["strong"] || 0)
    metrics["sorbet_typed_pct"] = total_files > 0 ? (typed_files.to_f / total_files * 100).round(2) : 0.0
  rescue JSON::ParserError
    warn "WARNING: Could not parse Sorbet coverage data."
  end

  # --- Mutant (mutation coverage) ---
  if File.exist?(MUTANT_RESULT_PATH)
    mutant_data = JSON.parse(File.read(MUTANT_RESULT_PATH))
    metrics["mutation_coverage"] = mutant_data["coverage"]
  else
    warn "WARNING: No mutant results found at #{MUTANT_RESULT_PATH}."
    warn "         Run mutant and pipe output through: bin/quality-metrics --record-mutant"
  end

  # --- CSS component coverage ---
  metrics.merge!(collect_css_metrics)

  # --- Presenter method violations ---
  metrics.merge!(collect_presenter_violations)

  metrics
end

def record_mutant(output_file)
  content = File.read(output_file)
  coverage_match = content[/Coverage:\s*([\d.]+)%/, 1]
  mutations_match = content[/Mutations:\s*(\d+)/, 1]
  kills_match = content[/Kills:\s*(\d+)/, 1]
  alive_match = content[/Alive:\s*(\d+)/, 1]

  result = {
    "coverage" => coverage_match&.to_f,
    "mutations" => mutations_match&.to_i,
    "kills" => kills_match&.to_i,
    "alive" => alive_match&.to_i,
    "recorded_at" => Time.now.iso8601
  }

  FileUtils.mkdir_p(File.dirname(MUTANT_RESULT_PATH))
  File.write(MUTANT_RESULT_PATH, JSON.pretty_generate(result))
  puts "Mutant results saved: coverage=#{result['coverage']}% (#{result['kills']}/#{result['mutations']} killed, #{result['alive']} alive)"
end

def load_baseline
  return nil unless File.exist?(BASELINE_PATH)
  JSON.parse(File.read(BASELINE_PATH))
end

def save_baseline(metrics)
  storable = metrics.reject { |k, _| k.to_s.start_with?("_") }
  File.write(BASELINE_PATH, JSON.pretty_generate(storable.merge("saved_at" => Time.now.iso8601)))
  puts "Baseline saved to #{BASELINE_PATH}"
end

def display_metrics(metrics)
  puts "=== Code Quality Metrics ==="
  puts "  Line coverage:        #{fmt(metrics['line_coverage'])}" if metrics["line_coverage"]
  puts "  Branch coverage:      #{fmt(metrics['branch_coverage'])}" if metrics["branch_coverage"]
  puts "  Sorbet typed files:   #{fmt(metrics['sorbet_typed_pct'])}" if metrics["sorbet_typed_pct"]
  puts "  Mutation coverage:    #{fmt(metrics['mutation_coverage'])}" if metrics["mutation_coverage"]
  if metrics["css_in_components_pct"]
    puts "  CSS in components:    #{fmt(metrics['css_in_components_pct'])}" \
         " (#{metrics['component_css_statements']} component / #{metrics['view_css_statements']} view statements)"
  end
  if metrics["presenter_method_violations"]
    total = metrics["_presenter_method_total"] || "?"
    puts "  Presenter violations: #{metrics['presenter_method_violations']} of #{total} public model methods"
  end
end

def fmt(value)
  "#{value&.round(2)}%"
end

def changed_app_files
  `git diff --name-only origin/master -- app/ lib/`.strip.split("\n")
    .select { |f| f.end_with?(".rb") }
    .select { |f| File.exist?(File.join(PROJECT_ROOT, f)) }
end

def file_coverage(lines)
  relevant = lines.compact
  return nil if relevant.empty?

  covered = relevant.count { |hits| hits > 0 }
  (covered.to_f / relevant.size * 100).round(2)
end

def branch_coverage_for_file(branches)
  return nil if branches.nil? || branches.empty?

  conditions = branches.values.flat_map(&:values)
  return nil if conditions.empty?

  covered = conditions.count { |hits| hits > 0 }
  (covered.to_f / conditions.size * 100).round(2)
end

def check_changed_file_coverage
  unless File.exist?(SIMPLECOV_RESULTSET_PATH)
    warn "WARNING: No SimpleCov resultset found. Cannot check per-file coverage."
    return []
  end

  resultset = JSON.parse(File.read(SIMPLECOV_RESULTSET_PATH))
  file_data = resultset.dig("RSpec", "coverage") || {}

  changed = changed_app_files
  return [] if changed.empty?

  puts "\n=== Changed File Coverage (line >= #{CHANGED_FILE_LINE_THRESHOLD}%, branch >= #{CHANGED_FILE_BRANCH_THRESHOLD}%) ==="
  failures = []

  changed.each do |relative_path|
    absolute_path = File.join(PROJECT_ROOT, relative_path)
    coverage = file_data[absolute_path]

    if coverage.nil?
      puts "  [FAIL] #{relative_path}: no coverage data (untested)"
      failures << "#{relative_path}: no coverage data — file is untested"
      next
    end

    line_cov = file_coverage(coverage["lines"])
    branch_cov = branch_coverage_for_file(coverage["branches"])

    line_ok = line_cov.nil? || line_cov >= CHANGED_FILE_LINE_THRESHOLD
    branch_ok = branch_cov.nil? || branch_cov >= CHANGED_FILE_BRANCH_THRESHOLD

    status = (line_ok && branch_ok) ? "OK" : "FAIL"
    parts = []
    parts << "line: #{line_cov}%" if line_cov
    parts << "branch: #{branch_cov}%" if branch_cov
    puts "  [#{status}] #{relative_path}: #{parts.join(', ')}"

    unless line_ok
      failures << "#{relative_path}: line coverage #{line_cov}% < #{CHANGED_FILE_LINE_THRESHOLD}%"
    end
    unless branch_ok
      failures << "#{relative_path}: branch coverage #{branch_cov}% < #{CHANGED_FILE_BRANCH_THRESHOLD}%"
    end
  end

  failures
end

def file_sorbet_sigil(absolute_path)
  first_line = File.foreach(absolute_path).first
  return nil unless first_line

  match = first_line[/^#\s*typed:\s*(\w+)/, 1]
  match&.downcase
end

def check_changed_file_sigils
  changed = changed_app_files
  return [] if changed.empty?

  puts "\n=== Changed File Sorbet Sigils (required: #{REQUIRED_SORBET_SIGILS.join('/')}) ==="
  failures = []

  changed.each do |relative_path|
    absolute_path = File.join(PROJECT_ROOT, relative_path)
    sigil = file_sorbet_sigil(absolute_path)
    ok = REQUIRED_SORBET_SIGILS.include?(sigil)

    status = ok ? "OK" : "FAIL"
    label = sigil || "none"
    puts "  [#{status}] #{relative_path}: typed: #{label}"

    unless ok
      failures << "#{relative_path}: Sorbet sigil is '#{label}', must be #{REQUIRED_SORBET_SIGILS.join('/')}"
    end
  end

  failures
end

def changed_view_erb_files
  `git diff --name-only origin/master -- app/views/`.strip.split("\n")
    .select { |f| f.end_with?(".html.erb") }
    .select { |f| File.exist?(File.join(PROJECT_ROOT, f)) }
end

def check_changed_view_css
  changed = changed_view_erb_files
  return [] if changed.empty?

  puts "\n=== Changed View CSS (views must not gain CSS statements) ==="
  failures = []

  changed.each do |relative_path|
    absolute_path = File.join(PROJECT_ROOT, relative_path)

    old_content = `git show origin/master:#{relative_path} 2>/dev/null`.force_encoding("utf-8")
    old_count   = css_statements_in_content(old_content)
    new_count   = css_statements_in_content(File.read(absolute_path, encoding: "utf-8"))
    delta       = new_count - old_count

    failed = delta > 0
    status = failed ? "FAIL" : "OK"
    puts "  [#{status}] #{relative_path}: #{old_count} -> #{new_count} (#{delta >= 0 ? '+' : ''}#{delta})"

    if failed
      failures << "#{relative_path}: +#{delta} CSS statement(s) added to a view template; move to a ViewComponent instead"
    end
  end

  failures
end

def changed_all_erb_files
  `git diff --name-only origin/master -- app/views/ app/components/`.strip.split("\n")
    .select { |f| f.end_with?(".html.erb") }
    .select { |f| File.exist?(File.join(PROJECT_ROOT, f)) }
end

def check_changed_erb_logic
  changed = changed_all_erb_files
  return [] if changed.empty?

  puts "\n=== Changed ERB Logic (must not gain presenter-level logic) ==="
  failures = []

  changed.each do |relative_path|
    absolute_path = File.join(PROJECT_ROOT, relative_path)

    old_content = `git show origin/master:#{relative_path} 2>/dev/null`.force_encoding("utf-8")
    old_count   = erb_logic_count(old_content)
    new_count   = erb_logic_count(File.read(absolute_path, encoding: "utf-8"))
    delta       = new_count - old_count

    failed = delta > 0
    status = failed ? "FAIL" : "OK"
    puts "  [#{status}] #{relative_path}: #{old_count} -> #{new_count} (#{delta >= 0 ? '+' : ''}#{delta})"

    if failed
      failures << "#{relative_path}: +#{delta} logic indicator(s) added to ERB; move ternaries, || fallbacks, and local assignments to a presenter or component method"
    end
  end

  failures
end

def check_sorbet_tc
  puts "\n=== Sorbet Type Check ==="
  output = `bundle exec srb tc 2>&1`
  status = $?.success?

  if status
    puts "  [OK] srb tc passed with no errors"
    []
  else
    error_count = output[/Errors:\s*(\d+)/, 1] || "unknown"
    puts "  [FAIL] srb tc found #{error_count} error(s)"
    output.each_line { |line| puts "    #{line}" unless line.strip.empty? }
    ["srb tc failed with #{error_count} error(s)"]
  end
end

def check_against_baseline(metrics, baseline)
  puts "\n=== Baseline Comparison (max regression: #{THRESHOLD} points) ==="
  failures = []

  METRIC_KEYS.each do |key|
    current = metrics[key]
    previous = baseline[key]
    next if current.nil? || previous.nil?

    if CEILING_METRICS.include?(key)
      current_int = current.to_i
      previous_int = previous.to_i
      delta = current_int - previous_int
      failed = current_int > previous_int
      status = failed ? "FAIL" : "OK"
      direction = delta.zero? ? "" : delta.positive? ? " (+#{delta})" : " (#{delta})"
      puts "  [#{status}] #{key}: #{current_int}#{direction} (ceiling: #{previous_int})"

      if failed
        failures << "#{key}: #{current_int} violations exceeds ceiling of #{previous_int}; " \
                    "new model methods only called from views/mailers must be moved to a presenter"
      end
    elsif FLOOR_METRICS.include?(key)
      # Floor metrics use the baseline value as a minimum.  The current value
      # must meet or exceed it; improvement is always welcome.
      #
      # Special case for mutation_coverage: when --since finds no mutations to
      # test (incremental run over a small diff), skip the check entirely.
      if key == "mutation_coverage"
        mutant_data = File.exist?(MUTANT_RESULT_PATH) ? JSON.parse(File.read(MUTANT_RESULT_PATH)) : {}
        mutations = mutant_data["mutations"] || 0

        if mutations.zero?
          puts "  [SKIP] #{key}: no mutations in changed code"
          next
        end
      end

      failed = current < previous
      status = failed ? "FAIL" : "OK"
      puts "  [#{status}] #{key}: #{current.round(2)}% (floor: #{previous.round(2)}%)"

      if failed
        failures << "#{key}: #{current.round(2)}% is below floor of #{previous.round(2)}%"
      end
    else
      regression = previous - current
      delta = current - previous
      symbol = delta >= 0 ? "+" : ""
      failed = regression > THRESHOLD
      status = failed ? "FAIL" : "OK"
      puts "  [#{status}] #{key}: #{previous.round(2)}% -> #{current.round(2)}% (#{symbol}#{delta.round(2)})"

      if failed
        failures << "#{key}: #{previous.round(2)}% -> #{current.round(2)}% (regressed #{regression.round(2)} points, max allowed: #{THRESHOLD})"
      end
    end
  end

  failures
end

# Prints a labelled list of every model method that is only called from the
# presentation layer, for use in --check mode output.
def display_presenter_violation_details(details)
  return if details.nil? || details.empty?

  puts "\n=== Presenter Method Violations (model methods only called from views/mailers) ==="
  details.each do |v|
    puts "  #{v['model']}##{v['method']}"
    v["sites"].each { |site| puts "    - #{site}" }
  end
end

# --- Main ---
require "fileutils"

mode = ARGV[0]

case mode
when "--save"
  metrics = collect_metrics
  display_metrics(metrics)
  save_baseline(metrics)
when "--check"
  baseline = load_baseline
  if baseline.nil?
    warn "No baseline found at #{BASELINE_PATH}. Run `bin/quality-metrics --save` first."
    exit 1
  end

  metrics = collect_metrics
  display_metrics(metrics)
  display_presenter_violation_details(metrics["_presenter_violation_details"])
  baseline_failures = check_against_baseline(metrics, baseline)
  changed_file_failures = check_changed_file_coverage
  changed_file_sigil_failures = check_changed_file_sigils
  changed_view_css_failures = check_changed_view_css
  sorbet_tc_failures = check_sorbet_tc
  changed_erb_logic_failures = check_changed_erb_logic

  failures = baseline_failures + changed_file_failures + changed_file_sigil_failures +
             changed_view_css_failures + changed_erb_logic_failures + sorbet_tc_failures

  if failures.any?
    puts "\nFAILED: Quality checks did not pass:"
    failures.each { |f| puts "  - #{f}" }
    exit 1
  else
    puts "\nAll metrics within acceptable range."
  end
when "--record-mutant"
  file = ARGV[1]
  if file.nil? || !File.exist?(file)
    warn "Usage: bin/quality-metrics --record-mutant <mutant-output-file>"
    exit 1
  end
  record_mutant(file)
else
  metrics = collect_metrics
  display_metrics(metrics)
  puts "\nCommands:"
  puts "  bin/quality-metrics --save               # save current metrics as baseline"
  puts "  bin/quality-metrics --check              # check against baseline (fails on >#{THRESHOLD}% regression)"
  puts "  bin/quality-metrics --record-mutant FILE # record mutant output for metrics"
end
